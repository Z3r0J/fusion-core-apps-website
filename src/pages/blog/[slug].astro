---
import BlogJsonLd from "@/components/BlogJsonLd.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { Locale } from "@/i18n/utils";

export async function getStaticPaths() {
	const posts = await getCollection("blog", ({ slug }) => slug.startsWith("en/"));
	return posts.map((post) => ({
		params: { slug: post.slug.replace("en/", "") },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await post.render();
const postSlug = post.slug.replace("en/", "");

const title = `${post.data.title} | FusionCore`;
const description = post.data.description;
const canonical = new URL(`/blog/${postSlug}`, Astro.site).href;
const ogImage = post.data.image || "/og-default.png";

const formattedDate = post.data.publishedAt.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

// ── Cross-locale sibling resolution ──
// If this post declares a `translationKey`, find every post sharing it (each
// lives under a different `<locale>/...` slug). Build the exact per-locale URL
// for hreflang and the language switcher. Without a key, only the current
// locale is advertised — preventing GSC 404s on inferred translations.
const allBlogPosts = await getCollection("blog");
const siblings = post.data.translationKey
	? allBlogPosts.filter((p) => p.data.translationKey === post.data.translationKey)
	: [post];

const localeLinksOverride: Partial<Record<Locale, string>> = {};
const availableLocales: Locale[] = [];
for (const sibling of siblings) {
	const [siblingLocale, ...rest] = sibling.slug.split("/");
	if (siblingLocale !== "en" && siblingLocale !== "es" && siblingLocale !== "pt") continue;
	const siblingSlug = rest.join("/");
	localeLinksOverride[siblingLocale as Locale] =
		siblingLocale === "en" ? `/blog/${siblingSlug}` : `/${siblingLocale}/blog/${siblingSlug}`;
	availableLocales.push(siblingLocale as Locale);
}
---

<BaseLayout
	{canonical}
	{description}
	{ogImage}
	{title}
	ogType="article"
	locale="en"
	availableLocales={availableLocales}
	localeLinks={post.data.translationKey ? localeLinksOverride : undefined}
>
	<BlogJsonLd post={post} url={canonical} />

	<article class="mx-auto max-w-3xl">

		{/* ── Breadcrumb ── */}
		<nav aria-label="Breadcrumb" class="mb-6 flex items-center gap-2 text-xs" style="color:var(--color-gray-400);">
			<a href="/" class="transition-colors hover:text-gray-600 dark:hover:text-white/60">Home</a>
			<span aria-hidden="true" style="opacity:0.35">/</span>
			<a href="/blog" class="transition-colors hover:text-gray-600 dark:hover:text-white/60">Blog</a>
			<span aria-hidden="true" style="opacity:0.35">/</span>
			<span class="truncate max-w-[200px]" style="color:var(--color-gray-600);" class="dark:!text-white/50">{post.data.title}</span>
		</nav>

		{/* ── Article header ── */}
		<header class="blog-article-header">
			{/* Tags */}
			{
				post.data.tags.length > 0 && (
					<div class="mb-5 flex flex-wrap gap-2">
						{post.data.tags.map((tag) => (
							<span class="blog-tag">{tag}</span>
						))}
					</div>
				)
			}

			<h1 class="blog-article-header__title">{post.data.title}</h1>

			{/* Byline */}
			<div class="blog-article-header__byline">
				<span class="author">{post.data.author}</span>
				<span aria-hidden="true" style="opacity:0.3">·</span>
				<time datetime={post.data.publishedAt.toISOString()}>{formattedDate}</time>
				{
					post.data.featured && (
						<>
							<span aria-hidden="true" style="opacity:0.3">·</span>
							<span class="blog-featured-badge">Featured</span>
						</>
					)
				}
			</div>
		</header>

		{/* ── Cover image ── */}
		{
			post.data.image && (
				<div class="blog-article-cover">
					<img
						alt={post.data.title}
						loading="eager"
						src={post.data.image}
					/>
				</div>
			)
		}

		{/* ── Body prose ── */}
		<div class="blog-prose">
			<Content />
		</div>

		{/* ── Article footer ── */}
		<footer class="mt-16 pt-8" style="border-top:1px solid rgba(0,0,0,0.08);" class="dark:!border-white/[0.07]">
			<div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
				<div style="font-size:13px;color:var(--color-gray-400);" class="dark:!text-white/30">
					<span class="font-semibold" style="color:var(--color-gray-700);" class="dark:!text-white/60">
						{post.data.author}
					</span>
					<span aria-hidden="true" style="margin:0 8px;opacity:0.4">·</span>
					<time datetime={post.data.publishedAt.toISOString()}>{formattedDate}</time>
				</div>

				<a class="blog-back-link" href="/blog">
					<svg aria-hidden="true" fill="none" height="14" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" width="14">
						<path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
					Back to Blog
				</a>
			</div>
		</footer>
	</article>
</BaseLayout>
