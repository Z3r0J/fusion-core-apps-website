---
import AppGrid from "@/components/AppGrid.tsx";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("apps");
const apps = entries.map(({ slug, data }) => ({
	slug,
	title: data.title,
	tagline: data.tagline,
	description: data.description,
	category: data.category,
	icon: data.icon,
	playUrl: data.playUrl,
	price: data.price ?? "Free",
	tags: data.tags ?? [],
	rating: data.rating ?? 4.5,
	downloadsLabel: data.downloads ?? "1K+",
	version: data.version,
	lastUpdated: data.lastUpdated,
}));
const canonical = new URL("/apps", Astro.site).href;
---

<BaseLayout
	{canonical}
	description="Browse all FusionCore Apps: Bible TPT Passion Translation, Biblia TLA en Español Fácil, and CartWise Grocery Shopping List. Free Android apps on Google Play."
	title="Apps — FusionCore Apps"
>
	<Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Apps", href: "/apps" }]} />
	<h1 class="mb-6 text-3xl font-bold">Browse FusionCore Apps</h1>
	<AppGrid apps={apps} client:load />
</BaseLayout>
