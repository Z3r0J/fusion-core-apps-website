---
import AppGrid from "@/components/AppGrid.tsx";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("apps");
const apps = entries.map(({ slug, data }) => ({
	slug,
	title: data.title,
	tagline: data.tagline,
	description: data.description,
	category: data.category,
	icon: data.icon,
	playUrl: data.playUrl,
	price: data.price ?? "Free",
	tags: data.tags ?? [],
	rating: data.rating ?? 4.5,
	downloadsLabel: data.downloads ?? "1K+",
	version: data.version,
	lastUpdated: data.lastUpdated,
	beta: data.beta ?? false,
	betaGroupUrl: data.betaGroupUrl,
}));

const canonical = new URL("/apps", Astro.site).href;
const totalDownloads = "3.3K+";
const categories = [...new Set(apps.map((a) => a.category))];
---

<BaseLayout
	{canonical}
	description="Browse all FusionCore Apps: Bible TPT Passion Translation, Biblia TLA en Español Fácil, and CartWise Grocery Shopping List. Free Android apps on Google Play."
	title="Android Apps: Bible, Grocery & Productivity — FusionCore"
>
	<script
		is:inline
		set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ItemList",
			"name": "FusionCore Apps",
			"description": "All Android apps published by FusionCore Apps on Google Play",
			"url": canonical,
			"numberOfItems": apps.length,
			"itemListElement": apps.map((app, i) => ({
				"@type": "ListItem",
				"position": i + 1,
				"name": app.title,
				"url": `https://www.fusioncoreapps.com/apps/${app.slug}`,
			})),
		}).replace(/</g, "\\u003c")}
		slot="head"
		type="application/ld+json"
	></script>
	<Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Apps", href: "/apps" }]} />

	<!-- Page Header -->
	<div class="relative mb-12 overflow-hidden -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 pt-12 pb-14">
		<!-- Dot grid bg -->
		<div
			class="absolute inset-0 opacity-60 dark:opacity-30"
			style="background-image: radial-gradient(circle, rgba(46,207,255,0.18) 1.5px, transparent 1.5px); background-size: 28px 28px;"
			aria-hidden="true"
		></div>
		<!-- Gradient fades -->
		<div class="absolute inset-0 bg-gradient-to-b from-white via-transparent to-white dark:from-gray-950 dark:via-transparent dark:to-gray-950" aria-hidden="true"></div>
		<div class="absolute inset-0 bg-gradient-to-r from-white via-transparent to-white dark:from-gray-950 dark:via-transparent dark:to-gray-950" aria-hidden="true"></div>

		<div class="relative mx-auto max-w-7xl">
			<div class="section-label mb-4">
				<span class="section-label__dot"></span>
				<span>Google Play · Verified Developer</span>
			</div>

			<div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
				<div>
					<h1
						class="text-[clamp(2.5rem,5vw,4rem)] font-extrabold tracking-tight leading-none text-gray-900 dark:text-white"
						style="letter-spacing: -0.04em;"
					>
						All Applications
					</h1>
					<p class="mt-3 text-lg text-gray-500 dark:text-gray-400 max-w-lg">
						{apps.length} free app{apps.length !== 1 ? "s" : ""} · {totalDownloads} downloads · {categories.join(", ")}
					</p>
				</div>

				<!-- Mini stats -->
				<div class="flex items-center gap-6 shrink-0">
					<div class="text-center">
						<div class="text-2xl font-extrabold text-gray-900 dark:text-white tracking-tight">{apps.length}</div>
						<div class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wider font-semibold mt-0.5">Apps</div>
					</div>
					<div class="w-px h-8 bg-gray-200 dark:bg-gray-800"></div>
					<div class="text-center">
						<div class="text-2xl font-extrabold text-gray-900 dark:text-white tracking-tight">{totalDownloads}</div>
						<div class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wider font-semibold mt-0.5">Downloads</div>
					</div>
					<div class="w-px h-8 bg-gray-200 dark:bg-gray-800"></div>
					<div class="text-center">
						<div class="text-2xl font-extrabold text-gray-900 dark:text-white tracking-tight">Free</div>
						<div class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wider font-semibold mt-0.5">Always</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- App Grid -->
	<AppGrid apps={apps} client:load />
</BaseLayout>
