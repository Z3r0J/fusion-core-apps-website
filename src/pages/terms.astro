---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import LegalLayout from "@/components/LegalLayout.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getEntry } from "astro:content";

const terms = await getEntry("legal", "terms");
if (!terms) throw new Error("Terms of service not found");
const { Content } = await terms.render();

const title = `${terms.data.title} — FusionCore Apps`;
const description = "Terms of service for FusionCore Apps mobile applications and website.";
const canonical = new URL("/terms", Astro.site).href;
---

<BaseLayout {canonical} {description} {title}>
	<Breadcrumbs
		items={[
			{ label: "Home", href: "/" },
			{ label: "Terms of Service", href: "/terms" },
		]}
	/>
	<LegalLayout eyebrow="Legal" icon="document" title={terms.data.title} updatedAt={terms.data.updatedAt}>
		<Content />
	</LegalLayout>
</BaseLayout>
