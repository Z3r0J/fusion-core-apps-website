---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import LegalLayout from "@/components/LegalLayout.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, type Locale } from "@/i18n/utils";
import { getEntry } from "astro:content";

export function getStaticPaths() {
	return [{ params: { locale: "es" } }, { params: { locale: "pt" } }];
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);

const terms = await getEntry("legal", `terms-${locale}` as "terms-es" | "terms-pt");
if (!terms) throw new Error(`Terms not found for locale: ${locale}`);
const { Content } = await terms.render();

const title = `${terms.data.title} — FusionCore Apps`;
const description = t("legal.termsDescription");
const canonical = new URL(`/${locale}/terms`, Astro.site).href;
---

<BaseLayout {canonical} {description} {title} locale={locale}>
	<Breadcrumbs items={[
		{ label: t("breadcrumbs.home"), href: `/${locale}` },
		{ label: t("breadcrumbs.terms"), href: `/${locale}/terms` },
	]} />
	<LegalLayout eyebrow="Legal" icon="document" title={terms.data.title} updatedAt={terms.data.updatedAt}>
		<Content />
	</LegalLayout>
</BaseLayout>
