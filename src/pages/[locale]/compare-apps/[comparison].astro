---
import ComparisonLayout from "@/components/ComparisonLayout.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { type Locale } from "@/i18n/utils";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
	const locales: Locale[] = ["es", "pt"];
	const paths = [];

	for (const locale of locales) {
		const entries = await getCollection("comparisons", ({ slug }) =>
			slug.startsWith(`${locale}/`),
		);
		for (const e of entries) {
			paths.push({
				params: {
					locale,
					comparison: `cartwise-vs-${e.data.competitorSlug}`,
				},
				props: { entry: e, locale },
			});
		}
	}

	return paths;
}

const { entry, locale } = Astro.props as { entry: any; locale: Locale };
const { Content } = await entry.render();

// Resolve related items from same-locale entries
const allLocale = await getCollection("comparisons", ({ slug }) =>
	slug.startsWith(`${locale}/`),
);
const relatedItems = (entry.data.relatedSlugs ?? [])
	.map((s: string) => {
		const match = allLocale.find((e: any) => e.data.competitorSlug === s);
		return match
			? { slug: match.data.competitorSlug, competitorName: match.data.competitorName }
			: null;
	})
	.filter(Boolean) as { slug: string; competitorName: string }[];

const canonical = new URL(
	`/${locale}/compare-apps/cartwise-vs-${entry.data.competitorSlug}`,
	Astro.site,
).href;
---

<BaseLayout
	title={entry.data.title}
	description={entry.data.description}
	ogImage="/images/apps/cartwise-grocery-shopping-list/icon.png"
	ogImageWidth={512}
	ogImageHeight={512}
	canonical={canonical}
	locale={locale}
	showFooterCta={false}
>
	<ComparisonLayout {...entry.data} locale={locale} relatedItems={relatedItems}>
		<Content />
	</ComparisonLayout>
</BaseLayout>
