---
import { AnimatedSection } from "@/components/AnimatedSection";
import AppCard from "@/components/AppCard.astro";
import { AppShowcase } from "@/components/AppShowcase";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, type Locale } from "@/i18n/utils";
import { getCollection } from "astro:content";
import { ArrowRight, Star } from "lucide-react";

export function getStaticPaths() {
	return [{ params: { locale: "es" } }, { params: { locale: "pt" } }];
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);

const apps = await getCollection("apps", ({ slug }) => slug.startsWith(`${locale}/`));
const featuredApps = apps.slice(0, 4);

const blogPosts = await getCollection("blog", ({ slug }) => slug.startsWith(`${locale}/`));
const latestPosts = blogPosts
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
	.slice(0, 3);

const canonical = new URL(`/${locale}`, Astro.site).href;

const testimonials =
	locale === "es"
		? [
				{
					quote: "La mejor app de la Biblia TLA que he encontrado. La traducción es muy fácil de entender y la interfaz es súper intuitiva. La uso cada día.",
					name: "María G.",
					app: "Biblia TLA en Español",
					initials: "MG",
					gradient: "from-brand-400 to-brand-600",
				},
				{
					quote: "CartWise me cambió la vida. Sin complicaciones, funciona perfecto. La comparto con mi esposo y nunca tenemos problemas.",
					name: "Ana P.",
					app: "CartWise Lista de Compras",
					initials: "AP",
					gradient: "from-accent-400 to-accent-600",
				},
				{
					quote: "Increíble app. Leer la Biblia en TPT es una experiencia completamente diferente. La interfaz es limpia y muy fácil de navegar.",
					name: "Roberto M.",
					app: "Bible TPT",
					initials: "RM",
					gradient: "from-purple-500 to-purple-700",
				},
			]
		: [
				{
					quote: "Melhor app da Bíblia TLA que encontrei. A tradução é muito fácil de ler e a interface é super intuitiva. Uso todo dia.",
					name: "Maria G.",
					app: "Biblia TLA em Português",
					initials: "MG",
					gradient: "from-brand-400 to-brand-600",
				},
				{
					quote: "CartWise mudou minha vida. Sem complicação, funciona perfeitamente. Compartilho com meu marido e nunca temos problemas.",
					name: "Ana P.",
					app: "CartWise Lista de Compras",
					initials: "AP",
					gradient: "from-accent-400 to-accent-600",
				},
				{
					quote: "App incrível. Ler a Bíblia em TPT é uma experiência completamente diferente. A interface é limpa e muito fácil de navegar.",
					name: "Roberto M.",
					app: "Bible TPT",
					initials: "RM",
					gradient: "from-purple-500 to-purple-700",
				},
			];

const features =
	locale === "es"
		? [
				{ num: "01", title: "Seguridad primero", desc: "Construidas con las mejores prácticas del sector. Tus datos nunca salen de tu dispositivo innecesariamente." },
				{ num: "02", title: "Experiencia de usuario", desc: "Interfaces intuitivas diseñadas alrededor de patrones de uso reales — no listas de funciones." },
				{ num: "03", title: "Alto rendimiento", desc: "Optimizadas desde cero. Tiempos de carga rápidos, animaciones fluidas, sin lag." },
				{ num: "04", title: "Nativas para Android", desc: "Construidas específicamente para Android. Siguen Material Design, se sienten como en casa en tu dispositivo." },
				{ num: "05", title: "Actualizaciones regulares", desc: "Mejoradas continuamente basándose en el feedback de usuarios. Siempre mejorando." },
				{ num: "06", title: "Soporte dedicado", desc: "Personas reales detrás de las apps. Respondemos, corregimos, escuchamos." },
			]
		: [
				{ num: "01", title: "Segurança em primeiro lugar", desc: "Criadas com as melhores práticas do setor. Seus dados nunca saem do dispositivo desnecessariamente." },
				{ num: "02", title: "Experiência do usuário", desc: "Interfaces intuitivas projetadas em torno de padrões de uso reais — não listas de funcionalidades." },
				{ num: "03", title: "Alto desempenho", desc: "Otimizadas do zero. Carregamento rápido, animações suaves, sem travamentos." },
				{ num: "04", title: "Nativas para Android", desc: "Criadas especificamente para Android. Seguem o Material Design, se encaixam perfeitamente no seu dispositivo." },
				{ num: "05", title: "Atualizações regulares", desc: "Melhoradas continuamente com base no feedback dos usuários. Sempre evoluindo." },
				{ num: "06", title: "Suporte dedicado", desc: "Pessoas reais por trás dos apps. Respondemos, corrigimos, ouvimos." },
			];
---

<BaseLayout
	{canonical}
	description={t("home.subtitle")}
	showHero={true}
	showFooterCta={false}
	title={`FusionCore Apps — ${locale === "es" ? "Apps Premium para Android" : "Apps Premium para Android"}`}
	locale={locale}
>
	<!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
	<div slot="hero">
		<div class="relative min-h-[88vh] flex items-center py-20 sm:py-28">
			<div class="hero-dot-grid absolute inset-0 -left-8 -right-8 sm:-left-12 sm:-right-12 lg:-left-16 lg:-right-16" aria-hidden="true"></div>
			<div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
				<div class="absolute -top-24 right-0 w-[40vw] h-[50vh] rounded-full bg-brand-400/20 dark:bg-brand-400/8 blur-[80px]"></div>
				<div class="absolute bottom-0 -left-8 w-[30vw] h-[40vh] rounded-full bg-accent-400/15 dark:bg-accent-400/5 blur-[80px]"></div>
			</div>
			<div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white dark:from-gray-950 to-transparent" aria-hidden="true"></div>

			<div class="relative z-10 grid w-full items-center gap-16 lg:grid-cols-[1fr_auto]">
				<div class="space-y-8 max-w-2xl">
					<div class="section-label">
						<span class="section-label__dot"></span>
						<span>{t("home.overline")}</span>
					</div>
					<h1 class="text-[clamp(2.8rem,6.5vw,5rem)] leading-[0.92] tracking-[-0.04em] font-extrabold text-gray-900 dark:text-white">
						{t("home.title")}<br/>
						<span class="gradient-text">{t("home.titleGradient")}</span>
					</h1>
					<p class="text-lg sm:text-xl leading-relaxed text-gray-600 dark:text-gray-400 max-w-lg">
						{t("home.subtitle")}
					</p>
					<div class="flex items-center gap-6 sm:gap-8 py-5 border-y border-gray-200 dark:border-gray-800">
						<div>
							<div class="editorial-num text-gray-900 dark:text-white">3.3K+</div>
							<div class="text-xs text-gray-500 dark:text-gray-500 mt-1 font-medium tracking-wide uppercase">{t("home.statsDownloads")}</div>
						</div>
						<div class="w-px h-10 bg-gray-200 dark:bg-gray-800 flex-shrink-0"></div>
						<div>
							<div class="editorial-num text-gray-900 dark:text-white">4.5★</div>
							<div class="text-xs text-gray-500 dark:text-gray-500 mt-1 font-medium tracking-wide uppercase">{t("home.statsRating")}</div>
						</div>
						<div class="w-px h-10 bg-gray-200 dark:bg-gray-800 flex-shrink-0"></div>
						<div>
							<div class="editorial-num text-gray-900 dark:text-white">100%</div>
							<div class="text-xs text-gray-500 dark:text-gray-500 mt-1 font-medium tracking-wide uppercase">{t("home.statsFree")}</div>
						</div>
					</div>
					<div class="flex flex-col sm:flex-row items-start gap-4 pt-2">
						<a class="button button--download group gap-2 px-7 py-3.5 text-base" href={`/${locale}/apps`}>
							<svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path d="M3 20.5V3.5C3 2.91 3.34 2.39 3.84 2.15L13.69 12L3.84 21.85C3.34 21.6 3 21.09 3 20.5Z" fill="currentColor" opacity="0.85"></path>
								<path d="M16.81 15.12L6.05 21.34L14.54 12.85L16.81 15.12Z" fill="currentColor" opacity="0.7"></path>
								<path d="M20.16 10.81C20.5 11.08 20.75 11.5 20.75 12C20.75 12.5 20.53 12.9 20.18 13.18L17.89 14.5L15.39 12L17.89 9.5L20.16 10.81Z" fill="currentColor"></path>
								<path d="M6.05 2.66L16.81 8.88L14.54 11.15L6.05 2.66Z" fill="currentColor" opacity="0.7"></path>
							</svg>
							<span>{t("home.ctaPrimary")}</span>
							<ArrowRight className="h-4 w-4 transition-transform group-hover:translate-x-1" />
						</a>
						<a class="button button--ghost border border-gray-300 dark:border-gray-700 px-7 py-3.5 text-base" href={`#features`}>
							{t("home.ctaSecondary")}
						</a>
					</div>
				</div>

				<div class="hidden lg:flex items-center" style="animation: float 7s ease-in-out infinite;">
					<AppShowcase client:load />
				</div>
			</div>
		</div>
	</div>

	<!-- ─── FEATURED APPS ─────────────────────────────────────────────────────── -->
	<AnimatedSection client:visible>
		<section class="featured-apps mt-4 mb-24">
			<div class="mb-12 flex items-end justify-between">
				<div>
					<div class="section-label mb-3">
						<span class="section-label__dot"></span>
						<span>{t("home.appsOverline")}</span>
					</div>
					<h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight">
						{t("home.appsTitle")}
					</h2>
				</div>
				{featuredApps.length > 0 && (
					<a class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-brand-500 hover:text-brand-600 dark:text-brand-400 dark:hover:text-brand-300 transition-colors" href={`/${locale}/apps`}>
						{t("home.appsViewAll")} <span>({apps.length})</span>
						<ArrowRight className="h-3.5 w-3.5" />
					</a>
				)}
			</div>

			{featuredApps.length > 0 ? (
				<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
					{featuredApps.map((app, index) => (
						<div class="animate-slide-up" style={`animation-delay: ${index * 80}ms`}>
							<AppCard app={app} featured={true} locale={locale} />
						</div>
					))}
				</div>
			) : (
				<div class="py-16 text-center">
					<p class="text-gray-500 dark:text-gray-400">{t("home.appsEmpty")}</p>
				</div>
			)}

			{featuredApps.length > 0 && (
				<div class="mt-8 text-center sm:hidden">
					<a class="button button--secondary" href={`/${locale}/apps`}>
						{t("home.appsViewAllMobile")}
						<span class="ml-1 text-gray-400">({apps.length})</span>
					</a>
				</div>
			)}
		</section>
	</AnimatedSection>

	<!-- ─── SOCIAL PROOF / STATS ─────────────────────────────────────────────── -->
	<section class="-mx-4 sm:-mx-6 lg:-mx-8 mb-0">
		<div class="social-proof-section relative overflow-hidden">
			<div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-[0.06] dark:opacity-30" style="background-image: radial-gradient(circle, rgba(46,207,255,0.6) 1px, transparent 1px); background-size: 32px 32px;"></div>

			<div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 sm:py-28">

				<!-- Stats row -->
				<AnimatedSection client:visible>
					<div class="grid grid-cols-2 gap-8 sm:grid-cols-4 mb-20">
						<div class="text-center">
							<div class="social-proof-stat-num">3.3K+</div>
							<div class="social-proof-stat-label">{t("home.statsDownloads")}</div>
						</div>
						<div class="text-center">
							<div class="social-proof-stat-num">4.5★</div>
							<div class="social-proof-stat-label">{t("home.statsRating")}</div>
						</div>
						<div class="text-center">
							<div class="social-proof-stat-num">3</div>
							<div class="social-proof-stat-label">{t("home.socialAppsPublished")}</div>
						</div>
						<div class="text-center">
							<div class="social-proof-stat-num" style="background: linear-gradient(135deg, #ff8a2a, #2ecfff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">{t("home.statsFree")}</div>
							<div class="social-proof-stat-label">{t("home.socialToDownload")}</div>
						</div>
					</div>
				</AnimatedSection>

				<!-- Testimonials -->
				<AnimatedSection client:visible delay={0.2}>
					<div class="mb-10">
						<div class="section-label text-brand-500 dark:text-brand-400 mb-4">
							<span class="section-label__dot" style="background-color: var(--color-brand-400);"></span>
							<span>{t("home.socialWhatUsersSay")}</span>
						</div>
						<h2 class="social-proof-heading">
							{t("home.socialTrustedBy")}
						</h2>
					</div>

					<div class="grid gap-5 sm:grid-cols-3">
						{testimonials.map((review) => (
							<div class="testimonial-card">
								<div class="mb-3 flex gap-0.5">
									{Array.from({ length: 5 }).map(() => (
										<Star className="h-4 w-4 text-yellow-400" fill="currentColor" />
									))}
								</div>
								<p class="testimonial-text">"{review.quote}"</p>
								<div class="testimonial-divider"></div>
								<div class="flex items-center gap-3 pt-4">
									<div class:list={[`h-8 w-8 rounded-full bg-gradient-to-br flex items-center justify-center text-white text-xs font-bold flex-shrink-0`, review.gradient]}>{review.initials}</div>
									<div>
										<div class="testimonial-name">{review.name}</div>
										<div class="testimonial-app">{review.app}</div>
									</div>
								</div>
							</div>
						))}
					</div>
				</AnimatedSection>
			</div>
		</div>
	</section>

	<!-- ─── FEATURES ─────────────────────────────────────────────────────────── -->
	<AnimatedSection client:visible delay={0.1}>
		<section id="features" class="-mx-4 sm:-mx-6 lg:-mx-8 bg-gray-50 dark:bg-transparent py-24">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="mb-14">
					<div class="section-label mb-3">
						<span class="section-label__dot"></span>
						<span>{t("home.featuresOverline")}</span>
					</div>
					<div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
						<h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight max-w-md">
							{t("home.featuresTitle")}
						</h2>
						<p class="text-gray-500 dark:text-gray-400 max-w-xs text-sm leading-relaxed">
							{t("home.featuresSubtitle")}
						</p>
					</div>
				</div>
				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{features.map((f) => (
						<div class="feature-item">
							<span class="feature-num">{f.num}</span>
							<div>
								<h3 class="font-bold text-gray-900 dark:text-white mb-1.5 text-base">{f.title}</h3>
								<p class="text-sm leading-relaxed text-gray-600 dark:text-gray-400">{f.desc}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
	</AnimatedSection>

	<!-- ─── BLOG TEASER ────────────────────────────────────────────────────── -->
	{latestPosts.length > 0 && (
		<AnimatedSection client:visible delay={0.1}>
			<section class="pb-24">
				<div class="mb-12 flex items-end justify-between">
					<div>
						<div class="section-label mb-3">
							<span class="section-label__dot"></span>
							<span>{t("home.blogOverline")}</span>
						</div>
						<h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight">
							{t("home.blogTitle")}
						</h2>
					</div>
					<a class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-brand-500 hover:text-brand-600 dark:text-brand-400 dark:hover:text-brand-300 transition-colors" href={`/${locale}/blog`}>
						{t("home.blogAllPosts")}
						<ArrowRight className="h-3.5 w-3.5" />
					</a>
				</div>
				<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
					{latestPosts.map((post, i) => (
						<a href={`/${locale}/blog/${post.slug.replace(`${locale}/`, "")}`} class="blog-teaser-card no-underline" style={`animation-delay: ${i * 80}ms`}>
							<div class="flex-1 space-y-3">
								{post.data.tags && post.data.tags.length > 0 && (
									<span class="inline-block rounded-full bg-brand-50 dark:bg-brand-950/50 px-3 py-1 text-[11px] font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">
										{post.data.tags[0]}
									</span>
								)}
								<h3 class="font-bold text-gray-900 dark:text-white text-base leading-snug group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
									{post.data.title}
								</h3>
								<p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2">
									{post.data.description}
								</p>
							</div>
							<div class="flex items-center justify-between mt-5 pt-4 border-t border-gray-100 dark:border-gray-700">
								<time class="text-xs text-gray-400 dark:text-gray-500 font-medium">
									{post.data.publishedAt.toLocaleDateString(locale === "es" ? "es-419" : "pt-BR", { month: "short", day: "numeric", year: "numeric" })}
								</time>
								<span class="inline-flex items-center gap-1 text-xs font-semibold text-brand-500 dark:text-brand-400">
									{t("home.blogRead")}
									<ArrowRight className="h-3 w-3 group-hover:translate-x-0.5 transition-transform" />
								</span>
							</div>
						</a>
					))}
				</div>
				<div class="mt-8 text-center sm:hidden">
					<a class="button button--secondary" href={`/${locale}/blog`}>{t("home.blogAllPosts")}</a>
				</div>
			</section>
		</AnimatedSection>
	)}

	<!-- ─── CTA ──────────────────────────────────────────────────────────────── -->
	<AnimatedSection client:visible delay={0.1}>
		<section class="-mx-4 sm:-mx-6 lg:-mx-8 mb-0">
			<div class="relative overflow-hidden" style="background: linear-gradient(135deg, #ff8a2a 0%, #e8455b 40%, #0b1c2d 100%);">
				<div aria-hidden="true" class="absolute inset-0 flex items-center justify-end overflow-hidden select-none pointer-events-none">
					<span class="text-white/5 font-extrabold pr-8" style="font-size: clamp(6rem, 18vw, 14rem); line-height: 1; letter-spacing: -0.05em; font-family: 'Urbanist', system-ui;">FREE</span>
				</div>
				<div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 sm:py-24">
					<div class="max-w-xl">
						<div class="section-label text-white/60 mb-5">
							<span class="inline-block h-1.5 w-1.5 rounded-full bg-white/60 mr-2"></span>
							<span>{t("home.ctaOverline")}</span>
						</div>
						<h2 class="text-4xl sm:text-5xl font-extrabold text-white tracking-tight mb-5" style="line-height: 0.95;">
							{t("home.ctaTitle")}
						</h2>
						<p class="text-lg text-white/75 mb-8 max-w-md leading-relaxed">
							{t("home.ctaBody")}
						</p>
						<div class="flex flex-col sm:flex-row items-start gap-4">
							<a class="button bg-white text-gray-900 hover:bg-gray-100 shadow-xl hover:shadow-2xl gap-2 px-7 py-3.5 text-base font-bold" href={`/${locale}/apps`}>
								{t("home.ctaBrowse")}
							</a>
							<a class="button border-2 border-white/30 text-white hover:bg-white/10 px-7 py-3.5 text-base" href={`/${locale}/contact`}>
								{t("home.ctaContact")}
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>
	</AnimatedSection>
</BaseLayout>
