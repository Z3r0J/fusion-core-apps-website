---
import AppGrid from "@/components/AppGrid.tsx";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, type Locale } from "@/i18n/utils";
import { getCollection } from "astro:content";

export function getStaticPaths() {
	return [{ params: { locale: "es" } }, { params: { locale: "pt" } }];
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);

const entries = await getCollection("apps", ({ slug }) => slug.startsWith(`${locale}/`));
const apps = entries.map(({ slug, data }) => ({
	slug: slug.replace(`${locale}/`, ""),
	title: data.title,
	tagline: data.tagline,
	description: data.description,
	category: data.category,
	icon: data.icon,
	playUrl: data.playUrl,
	price: data.price ?? "Free",
	tags: data.tags ?? [],
	rating: data.rating ?? 4.5,
	downloadsLabel: data.downloads ?? "1K+",
	version: data.version,
	lastUpdated: data.lastUpdated,
	beta: data.beta ?? false,
	betaGroupUrl: data.betaGroupUrl,
}));

const canonical = new URL(`/${locale}/apps`, Astro.site).href;
const totalDownloads = "3.3K+";
const categories = [...new Set(apps.map((a) => a.category))];
---

<BaseLayout
	{canonical}
	description={t("apps.title")}
	title={`${t("apps.title")} — FusionCore`}
	locale={locale}
>
	<Breadcrumbs items={[
		{ label: t("breadcrumbs.home"), href: `/${locale}` },
		{ label: t("breadcrumbs.apps"), href: `/${locale}/apps` },
	]} />

	<div class="relative mb-12 overflow-hidden -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 pt-12 pb-14">
		<div
			class="absolute inset-0 opacity-60 dark:opacity-30"
			style="background-image: radial-gradient(circle, rgba(46,207,255,0.18) 1.5px, transparent 1.5px); background-size: 28px 28px;"
			aria-hidden="true"
		></div>
		<div class="absolute inset-0 bg-gradient-to-b from-white via-transparent to-white dark:from-gray-950 dark:via-transparent dark:to-gray-950" aria-hidden="true"></div>
		<div class="absolute inset-0 bg-gradient-to-r from-white via-transparent to-white dark:from-gray-950 dark:via-transparent dark:to-gray-950" aria-hidden="true"></div>

		<div class="relative mx-auto max-w-7xl">
			<div class="section-label mb-4">
				<span class="section-label__dot"></span>
				<span>{t("apps.overline")}</span>
			</div>
			<div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
				<div>
					<h1
						class="text-[clamp(2.5rem,5vw,4rem)] font-extrabold tracking-tight leading-none text-gray-900 dark:text-white"
						style="letter-spacing: -0.04em;"
					>
						{t("apps.title")}
					</h1>
					<p class="mt-3 text-lg text-gray-500 dark:text-gray-400 max-w-lg">
						{apps.length} app{apps.length !== 1 ? "s" : ""} · {totalDownloads} {t("apps.downloads").toLowerCase()} · {categories.join(", ")}
					</p>
				</div>
				<div class="flex items-center gap-6 shrink-0">
					<div class="text-center">
						<div class="text-2xl font-extrabold text-gray-900 dark:text-white tracking-tight">{apps.length}</div>
						<div class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wider font-semibold mt-0.5">{t("apps.apps")}</div>
					</div>
					<div class="w-px h-8 bg-gray-200 dark:bg-gray-800"></div>
					<div class="text-center">
						<div class="text-2xl font-extrabold text-gray-900 dark:text-white tracking-tight">{totalDownloads}</div>
						<div class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wider font-semibold mt-0.5">{t("apps.downloads")}</div>
					</div>
					<div class="w-px h-8 bg-gray-200 dark:bg-gray-800"></div>
					<div class="text-center">
						<div class="text-2xl font-extrabold text-gray-900 dark:text-white tracking-tight">{t("apps.free")}</div>
						<div class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wider font-semibold mt-0.5">{t("apps.always")}</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<AppGrid apps={apps} locale={locale} client:load />
</BaseLayout>
