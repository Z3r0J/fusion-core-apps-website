---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import LegalLayout from "@/components/LegalLayout.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, type Locale } from "@/i18n/utils";
import { getEntry } from "astro:content";

export function getStaticPaths() {
	return [{ params: { locale: "es" } }, { params: { locale: "pt" } }];
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);

const policy = await getEntry("legal", `cartwise-privacy-${locale}` as "cartwise-privacy-es" | "cartwise-privacy-pt");
if (!policy) throw new Error(`CartWise privacy policy not found for locale: ${locale}`);
const { Content } = await policy.render();

const title = `${policy.data.title} — CartWise`;
const description = t("legal.cartwisePrivacyDescription");
const canonical = new URL(`/${locale}/cartwise/privacy`, Astro.site).href;
---

<BaseLayout {canonical} {description} {title} locale={locale}>
	<Breadcrumbs items={[
		{ label: t("breadcrumbs.home"), href: `/${locale}` },
		{ label: t("breadcrumbs.cartwise"), href: `/${locale}/cartwise` },
		{ label: t("breadcrumbs.cartwisePrivacy"), href: `/${locale}/cartwise/privacy` },
	]} />
	<LegalLayout eyebrow="Legal" icon="shield" title={policy.data.title} updatedAt={policy.data.updatedAt}>
		<Content />
	</LegalLayout>
</BaseLayout>
