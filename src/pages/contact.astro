---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import ContactForm from "@/components/ContactForm.tsx";
import FaqAccordion from "@/components/FaqAccordion.tsx";
import FaqJsonLd from "@/components/FaqJsonLd.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const canonical = new URL("/contact", Astro.site).href;

const faqs = [
	{
		question: "How do I download your apps?",
		answer:
			"All our apps are available on the Google Play Store. Visit our apps page and click any app to be redirected to the Play Store for download.",
	},
	{
		question: "Are your apps free?",
		answer:
			"Most of our apps are free to download and use. Some may offer premium features through in-app purchases. Check each app's details page for specific pricing information.",
	},
	{
		question: "How do I report a bug or issue?",
		answer:
			'Use the contact form with "Bug Report" as the subject, or leave a review on the Google Play Store. We actively monitor and respond to all feedback.',
	},
	{
		question: "Do you offer custom app development?",
		answer:
			'Yes! We offer custom mobile app development services. Contact us with "Business Inquiry" as the subject to discuss your project requirements and get a quote.',
	},
];
---

<BaseLayout
	{canonical}
	description="Get in touch with FusionCore Apps. Have questions about Bible TPT, Biblia TLA, or Claimly? We're here to help. Contact us or browse our FAQ."
	title="Contact FusionCore Apps — Support, Feedback & Partnerships"
>
	<FaqJsonLd faqs={faqs} />
	<Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Contact", href: "/contact" }]} />

	{/* ── Page header ── */}
	<header style="padding:52px 0 44px;border-bottom:1px solid rgba(0,0,0,0.07);margin-bottom:48px;" class="dark:!border-[rgba(255,255,255,0.06)]">
		<p
			style="display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:0.11em;text-transform:uppercase;color:var(--color-brand-500);margin-bottom:12px;"
		>
			<span style="display:block;width:22px;height:2px;border-radius:2px;background:var(--color-brand-400);flex-shrink:0;"></span>
			FusionCore Apps
		</p>
		<div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
			<h1
				style="font-family:var(--font-display);font-size:clamp(2.4rem,6vw,3.75rem);font-weight:900;letter-spacing:-0.045em;line-height:1;color:var(--color-gray-900);"
				class="dark:!text-white"
			>
				Get in touch
			</h1>
			<p style="font-size:15px;max-width:360px;line-height:1.65;" class="text-gray-500 dark:text-[rgba(255,255,255,0.38)] sm:text-right">
				Questions, feedback, or partnership ideas — we read every message.
			</p>
		</div>
	</header>

	{/* ── Two-column layout ── */}
	<div class="grid gap-10 lg:grid-cols-3 lg:gap-12">

		{/* ── Left: contact info ── */}
		<div class="flex flex-col gap-4 lg:col-span-1">
			<p
				style="font-size:11px;font-weight:700;letter-spacing:0.11em;text-transform:uppercase;color:var(--color-gray-400);margin-bottom:4px;"
				class="dark:!text-[rgba(255,255,255,0.24)]"
			>
				Contact information
			</p>

			{/* Email */}
			<a class="contact-method" href="mailto:jeanrey.ese@gmail.com">
				<div
					class="contact-method__icon"
					style="background:rgba(46,207,255,0.09);border:1px solid rgba(46,207,255,0.16);"
				>
					<svg fill="none" height="17" stroke="rgba(46,207,255,0.80)" stroke-width="1.7" viewBox="0 0 24 24" width="17">
						<path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</div>
				<div class="min-w-0">
					<p class="contact-method__title">Email us</p>
					<p class="contact-method__body">jeanrey.ese@gmail.com</p>
					<span class="contact-method__link">
						Write now
						<svg fill="none" height="11" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" width="11">
							<path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</span>
				</div>
			</a>

			{/* Support */}
			<a class="contact-method" href="mailto:jeanrey.ese@gmail.com?subject=App Support Request">
				<div
					class="contact-method__icon"
					style="background:rgba(46,207,255,0.07);border:1px solid rgba(46,207,255,0.13);"
				>
					<svg fill="none" height="17" stroke="rgba(46,207,255,0.72)" stroke-width="1.7" viewBox="0 0 24 24" width="17">
						<path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</div>
				<div class="min-w-0">
					<p class="contact-method__title">App support</p>
					<p class="contact-method__body">For bugs, issues &amp; help with our apps.</p>
					<span class="contact-method__link">
						Get help
						<svg fill="none" height="11" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" width="11">
							<path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</span>
				</div>
			</a>

			{/* Business */}
			<a class="contact-method" href="mailto:jeanrey.ese@gmail.com?subject=Business Inquiry">
				<div
					class="contact-method__icon"
					style="background:rgba(255,138,42,0.09);border:1px solid rgba(255,138,42,0.16);"
				>
					<svg fill="none" height="17" stroke="rgba(255,138,42,0.80)" stroke-width="1.7" viewBox="0 0 24 24" width="17">
						<path d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</div>
				<div class="min-w-0">
					<p class="contact-method__title">Business inquiries</p>
					<p class="contact-method__body">Partnerships, collaborations &amp; custom dev.</p>
					<span class="contact-method__link" style="color:var(--color-accent-500);">
						Let's talk
						<svg fill="none" height="11" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" width="11">
							<path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</span>
				</div>
			</a>

			{/* Response time note */}
			<div
				style="margin-top:4px;padding:14px 16px;border-radius:12px;background:rgba(46,207,255,0.04);border:1px solid rgba(46,207,255,0.10);"
				class="dark:!bg-[rgba(46,207,255,0.03)]"
			>
				<p style="font-size:12.5px;line-height:1.65;" class="text-gray-500 dark:text-[rgba(255,255,255,0.30)]">
					<span class="font-semibold text-gray-800 dark:text-[rgba(255,255,255,0.60)]">Response within 24 hours.</span>
					{" "}We're a small indie team — we read every message and respond personally.
				</p>
			</div>
		</div>

		{/* ── Right: form ── */}
		<div class="lg:col-span-2">
			<ContactForm client:load />
		</div>
	</div>

	{/* ── FAQ section ── */}
	<section style="margin-top:80px;padding-top:56px;border-top:1px solid rgba(0,0,0,0.07);" class="dark:!border-[rgba(255,255,255,0.06)]">
		<div class="mb-10 text-center">
			<p
				style="display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:0.11em;text-transform:uppercase;color:var(--color-brand-500);margin-bottom:12px;"
			>
				<span style="display:block;width:16px;height:2px;border-radius:2px;background:var(--color-brand-400);"></span>
				FAQ
				<span style="display:block;width:16px;height:2px;border-radius:2px;background:var(--color-brand-400);"></span>
			</p>
			<h2
				style="font-family:var(--font-display);font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;letter-spacing:-0.04em;line-height:1.05;margin-bottom:10px;"
				class="text-gray-900 dark:text-white"
			>
				Frequently asked questions
			</h2>
			<p style="font-size:15px;" class="text-gray-500 dark:text-[rgba(255,255,255,0.38)]">
				Quick answers to common questions about our apps.
			</p>
		</div>

		<FaqAccordion faqs={faqs} client:visible />
	</section>
</BaseLayout>
