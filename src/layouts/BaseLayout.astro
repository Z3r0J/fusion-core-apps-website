---
import "@/styles/global.css";

import GooglePlayLogo from "@/assets/gplay-logo.svg";
import ThemeToggle from "@/components/ThemeToggle.tsx";

const {
	title = "FusionCore Apps — Premium Mobile Applications",
	description = "Professional mobile app development studio delivering secure, innovative, and user-friendly applications for Android and iOS platforms. Transform your ideas into powerful digital experiences.",
	ogImage = "/og-default.png",
	ogType = "website",
	canonical,
	noindex = false,
	bodyClass = "",
	showHero = false,
	locale = "en",
	showFooterCta = true,
} = Astro.props;

const year = new Date().getFullYear();
const currentPath = Astro.url.pathname;
// IMPORTANT: Use Astro.url.pathname (not Astro.url) — pathname strips query params.
// Using Astro.url.href would bake ?utm_source=... or ?from=AppAgg.com into the canonical,
// creating duplicate-content variants that confuse Googlebot. Never change this to Astro.url.
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;

// Handle ogImage: if it's already a full URL or data URI, use as-is; otherwise make it absolute
const resolvedOgImage =
	ogImage.startsWith("http://") || ogImage.startsWith("https://") || ogImage.startsWith("data:")
		? ogImage
		: new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html class="scroll-smooth" lang={locale}>
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1, viewport-fit=cover" name="viewport" />
		<title>{title}</title>
		<meta content={description} name="description" />
		<meta content={noindex ? "noindex,nofollow" : "index,follow"} name="robots" />
		<link href={canonicalUrl} rel="canonical" />
		<link href={canonicalUrl} hreflang="x-default" rel="alternate" />
		<link href={canonicalUrl} hreflang={locale} rel="alternate" />

		<meta content={ogType} property="og:type" />
		<meta content={new URL(Astro.url.pathname, Astro.site).href} property="og:url" />
		<meta content={title} property="og:title" />
		<meta content={description} property="og:description" />
		<meta content={resolvedOgImage} property="og:image" />
		<meta content="1200" property="og:image:width" />
		<meta content="630" property="og:image:height" />
		<meta content="FusionCore Apps" property="og:site_name" />
		<meta content={locale === "es" ? "es_ES" : "en_US"} property="og:locale" />

		<meta content="summary_large_image" name="twitter:card" />
		<meta content="@FusioncoreApps" name="twitter:site" />
		<meta content={new URL(Astro.url.pathname, Astro.site).href} name="twitter:url" />
		<meta content={title} name="twitter:title" />
		<meta content={description} name="twitter:description" />
		<meta content={resolvedOgImage} name="twitter:image" />

		<meta content="#2ECFFF" name="theme-color" media="(prefers-color-scheme: light)" />
		<meta content="#0b1c2d" name="theme-color" media="(prefers-color-scheme: dark)" />
		<meta content="light dark" name="color-scheme" />
		<meta content="yes" name="mobile-web-app-capable" />
		<meta content="default" name="apple-mobile-web-app-status-bar-style" />

		<link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
		<link rel="preconnect" href="https://www.gstatic.com" crossorigin />
		<link
			rel="preload"
			href="https://fonts.bunny.net/css?family=urbanist:700,800,900|dm-sans:400,500&display=swap"
			as="style"
		/>
		<link href="https://fonts.bunny.net/css?family=urbanist:400,500,600,700,800,900|dm-sans:300,400,500,600&display=swap" rel="stylesheet" />

		<link href="/favicon.svg" rel="icon" type="image/svg+xml" />
		<!-- apple-touch-icon.png must be a 180×180 PNG at /public/apple-touch-icon.png -->
		<link href="/apple-touch-icon.png" rel="apple-touch-icon" sizes="180x180" />

		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Organization",
				"name": "FusionCore Apps",
				"description": "Professional mobile app development studio",
				"url": "https://www.fusioncoreapps.com",
				"logo": {
					"@type": "ImageObject",
					"url": "https://www.fusioncoreapps.com/logo.png",
					"width": 528,
					"height": 551
				},
				"foundingDate": "2024",
				"sameAs": ["https://play.google.com/store/apps/dev?id=5173536626513659112"]
			}
		</script>
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"url": "https://www.fusioncoreapps.com",
				"name": "FusionCore Apps",
				"potentialAction": {
					"@type": "SearchAction",
					"target": "https://www.fusioncoreapps.com/apps?q={search_term_string}",
					"query-input": "required name=search_term_string"
				}
			}
		</script>

		<script is:inline>
			(function () {
				const stored = localStorage.getItem("theme");
				const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				const isDark = stored === "dark" || (!stored && prefersDark);

				if (isDark) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
		<slot name="head" />

		<!-- Firebase Analytics -->
		{import.meta.env.PUBLIC_FIREBASE_MEASUREMENT_ID && (
			<script type="module" define:vars={{
				apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
				authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
				projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
				storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
				messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
				appId: import.meta.env.PUBLIC_FIREBASE_APP_ID,
				measurementId: import.meta.env.PUBLIC_FIREBASE_MEASUREMENT_ID,
			}}>
				import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js";
				import { getAnalytics } from "https://www.gstatic.com/firebasejs/11.6.0/firebase-analytics.js";
				const app = initializeApp({ apiKey, authDomain, projectId, storageBucket, messagingSenderId, appId, measurementId });
				getAnalytics(app);
			</script>
		)}
	</head><body class:list={[`min-h-screen antialiased`, `${bodyClass}`]}>
		<!-- Skip to content link for accessibility -->
		<a
			class="button button--primary sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50"
			href="#main"
		>
			Skip to main content
		</a>

		<!-- ── Header: Morphing Glass Pill ── -->
		<header id="site-header" class="header sticky top-0 z-40 w-full">
			<div class="px-4 py-3 sm:px-5">
				<div
					id="header-pill"
					class="header__pill mx-auto flex max-w-7xl items-center justify-between"
				>
					<!-- Logo -->
					<a href="/" class="header__logo group flex min-w-0 flex-shrink-0 items-center gap-2.5">
						<img
							src="/logo.png"
							alt="FusionCore Apps"
							class="h-9 w-9 flex-shrink-0 rounded-xl object-contain transition-transform duration-300 group-hover:scale-105"
						/>
						<span
							class="header__wordmark gradient-text overflow-hidden whitespace-nowrap font-bold"
							style="font-family: var(--font-display); letter-spacing: -0.025em; font-size: 15px;"
						>FusionCore Apps</span>
					</a>

					<!-- Desktop links -->
					<ul class="hidden items-center gap-0.5 md:flex" role="menubar">
						<li role="none">
							<a
								class:list={["nav-pill-link", { "nav-pill-link--active": currentPath.startsWith("/apps") }]}
								href="/apps"
								role="menuitem"
							>Apps</a>
						</li>
						<li role="none">
							<a
								class:list={["nav-pill-link", { "nav-pill-link--active": currentPath.startsWith("/blog") }]}
								href="/blog"
								role="menuitem"
							>Blog</a>
						</li>
						<li role="none">
							<a
								class:list={["nav-pill-link", { "nav-pill-link--active": currentPath === "/privacy" }]}
								href="/privacy"
								role="menuitem"
							>Privacy</a>
						</li>
						<li role="none">
							<a
								class:list={["nav-pill-link", { "nav-pill-link--active": currentPath === "/contact" }]}
								href="/contact"
								role="menuitem"
							>Contact</a>
						</li>
					</ul>

					<!-- Actions -->
					<div class="flex flex-shrink-0 items-center gap-2">
						<ThemeToggle client:load />

						<!-- Desktop CTA -->
						<a href="/apps" class="nav-cta hidden items-center gap-1.5 md:inline-flex">
							Browse Apps
							<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M9 18l6-6-6-6"/>
							</svg>
						</a>

						<!-- Animated hamburger for mobile -->
						<button
							id="menu-btn"
							class="menu-btn flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-gray-100 text-gray-600 transition-colors duration-200 hover:bg-gray-200 focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 focus:outline-none dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700 md:hidden"
							aria-label="Open navigation menu"
							aria-expanded="false"
							aria-controls="mobile-overlay"
						>
							<span class="flex h-5 w-5 flex-col items-center justify-center gap-[5.5px]">
								<span class="menu-btn__bar w-5"></span>
								<span class="menu-btn__bar w-[14px] self-start"></span>
								<span class="menu-btn__bar w-5"></span>
							</span>
						</button>
					</div>
				</div>
			</div>
		</header>

		<!-- ── Mobile Fullscreen Overlay ── -->
		<div
			id="mobile-overlay"
			class="mobile-overlay fixed inset-0 z-50 flex flex-col md:hidden"
			aria-hidden="true"
			role="dialog"
			aria-modal="true"
			aria-label="Navigation menu"
		>
			<!-- Top bar -->
			<div class="flex flex-shrink-0 items-center justify-between px-6 py-4">
				<a href="/" class="flex items-center gap-2.5" id="overlay-logo">
					<img src="/logo.png" alt="FusionCore Apps" class="h-8 w-8 flex-shrink-0 rounded-lg object-contain" />
					<span class="gradient-text font-bold" style="font-family: var(--font-display); font-size: 15px; letter-spacing: -0.02em;">
						FusionCore Apps
					</span>
				</a>
				<button
					id="close-overlay"
					class="flex h-10 w-10 items-center justify-center rounded-xl bg-gray-100 text-gray-600 transition-colors duration-200 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700"
					aria-label="Close navigation menu"
				>
					<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 6L6 18M6 6l12 12"/>
					</svg>
				</button>
			</div>

			<!-- Nav links — large editorial type -->
			<div class="flex flex-1 flex-col justify-center px-8 -mt-6">
				<nav aria-label="Mobile navigation links">
					<ul class="divide-y divide-gray-200/70 dark:divide-white/5">
						<li class="mobile-link-item">
							<a
								class:list={["mobile-nav-link", { "mobile-nav-link--active": currentPath.startsWith("/apps") }]}
								href="/apps"
								id="mobile-link-apps"
							>
								<span>Apps</span>
								<svg class="h-6 w-6 flex-shrink-0 opacity-30 transition-opacity duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
							</a>
						</li>
						<li class="mobile-link-item">
							<a
								class:list={["mobile-nav-link", { "mobile-nav-link--active": currentPath.startsWith("/blog") }]}
								href="/blog"
								id="mobile-link-blog"
							>
								<span>Blog</span>
								<svg class="h-6 w-6 flex-shrink-0 opacity-30 transition-opacity duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
							</a>
						</li>
						<li class="mobile-link-item">
							<a
								class:list={["mobile-nav-link", { "mobile-nav-link--active": currentPath === "/privacy" }]}
								href="/privacy"
								id="mobile-link-privacy"
							>
								<span>Privacy</span>
								<svg class="h-6 w-6 flex-shrink-0 opacity-30 transition-opacity duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
							</a>
						</li>
						<li class="mobile-link-item">
							<a
								class:list={["mobile-nav-link", { "mobile-nav-link--active": currentPath === "/contact" }]}
								href="/contact"
								id="mobile-link-contact"
							>
								<span>Contact</span>
								<svg class="h-6 w-6 flex-shrink-0 opacity-30 transition-opacity duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
							</a>
						</li>
					</ul>
				</nav>

				<!-- Subtle stat row -->
				<p class="mt-8 text-xs font-medium tracking-widest uppercase text-gray-400 dark:text-gray-600">
					Free Android apps &nbsp;·&nbsp; 3 apps &nbsp;·&nbsp; 3.3K+ downloads
				</p>
			</div>

			<!-- Bottom CTA -->
			<div class="mobile-overlay__footer flex-shrink-0 px-8 pb-12 pt-6">
				<a
					href="/apps"
					id="mobile-cta"
					class="flex w-full items-center justify-center gap-2 rounded-2xl py-4 text-base font-bold text-white shadow-lg"
					style="background: linear-gradient(135deg, #ff8a2a 0%, #e8455b 100%);"
				>
					Browse All Apps
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M9 18l6-6-6-6"/>
					</svg>
				</a>
			</div>
		</div>

		<!-- Main Content -->
		<main class="main flex-1" id="main" role="main">
			{
				showHero && (
					<section class="hero relative overflow-hidden">
						<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
							<slot name="hero" />
						</div>
					</section>
				)
			}

			<div class:list={{ "py-16 sm:py-24": showHero, "py-8 sm:py-12": !showHero }}>
				<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
					<slot />
				</div>
			</div>
		</main>

		<!-- ── Footer ── -->
		<footer role="contentinfo">

			<!-- Top gradient line (always visible) -->
			<div class="h-px w-full" style="background: linear-gradient(90deg, transparent 0%, #ff8a2a 25%, #e8455b 50%, #2ecfff 75%, transparent 100%);"></div>

			<!-- CTA Island — theme-aware -->
			{showFooterCta && (
				<div class="footer-cta-island">
					<!-- Ambient glow accents (visible in dark, subtle in light) -->
					<div aria-hidden="true" class="pointer-events-none absolute inset-0">
						<div class="absolute -top-24 right-1/4 h-64 w-64 rounded-full blur-[80px] opacity-30 dark:opacity-100" style="background: rgba(255,138,42,0.15);"></div>
						<div class="absolute -bottom-16 left-1/4 h-56 w-56 rounded-full blur-[80px] opacity-20 dark:opacity-100" style="background: rgba(46,207,255,0.12);"></div>
					</div>
					<!-- Dot grid texture -->
					<div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-[0.07] dark:opacity-20" style="background-image: radial-gradient(circle, rgba(46,207,255,0.5) 1px, transparent 1px); background-size: 28px 28px;"></div>

					<div class="relative mx-auto flex max-w-7xl flex-col items-center gap-6 px-4 py-20 text-center sm:px-6 lg:px-8">
						<div class="footer-cta-island__label section-label">
							<span class="inline-block h-1.5 w-1.5 rounded-full mr-2 opacity-50"></span>
							Available on Google Play
						</div>
						<h2 class="footer-cta-island__title">
							Premium apps.<br/>Free to start.
						</h2>
						<p class="footer-cta-island__body">
							Every app is free to download on Google Play. Some unlock additional features through an optional subscription — but the core experience is always free.
						</p>
						<a href="/apps" class="footer-cta-island__btn">
							<svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="none">
								<path d="M3 20.5V3.5C3 2.91 3.34 2.39 3.84 2.15L13.69 12L3.84 21.85C3.34 21.6 3 21.09 3 20.5Z" fill="#2ecfff" opacity="0.9"/>
								<path d="M16.81 15.12L6.05 21.34L14.54 12.85L16.81 15.12Z" fill="#ffc107" opacity="0.9"/>
								<path d="M20.16 10.81C20.5 11.08 20.75 11.5 20.75 12C20.75 12.5 20.53 12.9 20.18 13.18L17.89 14.5L15.39 12L17.89 9.5L20.16 10.81Z" fill="#ff3e00"/>
								<path d="M6.05 2.66L16.81 8.88L14.54 11.15L6.05 2.66Z" fill="#00e081" opacity="0.9"/>
							</svg>
							Browse All Apps
						</a>
					</div>
				</div>
			)}

			<!-- Main footer body (light/dark responsive) -->
			<div class="footer-body">
				<!-- Subtle top separator -->
				<div class="h-px w-full bg-gray-200 dark:bg-gray-800/60"></div>

				<div class="relative mx-auto max-w-7xl px-4 pb-0 pt-14 sm:px-6 lg:px-8">
					<div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-[2.2fr_1fr_1fr_1.3fr]">

						<!-- Column 1: Brand -->
						<div class="space-y-6">
							<a href="/" class="inline-flex items-center gap-3 group">
								<img
									src="/logo.png"
									alt="FusionCore Apps"
									class="h-10 w-10 rounded-xl object-contain transition-transform duration-300 group-hover:scale-105"
								/>
								<span class="font-bold text-gray-900 dark:text-white" style="font-family: var(--font-display); font-size: 16px; letter-spacing: -0.025em;">
									FusionCore Apps
								</span>
							</a>

							<p class="max-w-[240px] text-sm leading-relaxed text-gray-500 dark:text-gray-500">
								Free Android apps crafted with care — for Bible reading, shopping, and everyday life.
							</p>

							<!-- Mini stat strip -->
							<div class="flex items-center gap-4">
								<div>
									<div class="text-base font-bold text-gray-900 dark:text-white" style="font-family: var(--font-display); letter-spacing: -0.03em;">3.3K+</div>
									<div class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-600">Downloads</div>
								</div>
								<div class="h-7 w-px bg-gray-200 dark:bg-gray-800"></div>
								<div>
									<div class="text-base font-bold text-gray-900 dark:text-white" style="font-family: var(--font-display); letter-spacing: -0.03em;">4.5★</div>
									<div class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-600">Rating</div>
								</div>
								<div class="h-7 w-px bg-gray-200 dark:bg-gray-800"></div>
								<div>
									<div class="text-base font-bold text-gray-900 dark:text-white" style="font-family: var(--font-display); letter-spacing: -0.03em;">Free</div>
									<div class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-600">Always</div>
								</div>
							</div>

							<!-- Google Play badge -->
							<a
								href="https://play.google.com/store/apps/dev?id=5173536626513659112"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Get it on Google Play"
								class="inline-flex items-center gap-2 rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 transition-all duration-200 hover:border-gray-400 hover:text-gray-900 dark:border-gray-800 dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-white"
							>
								<GooglePlayLogo class="h-4 w-4" />
								<span>Google Play</span>
							</a>
						</div>

						<!-- Column 2: Navigation -->
						<div>
							<h3 class="footer__col-title">Navigation</h3>
							<ul class="space-y-0.5">
								<li><a class="footer__link" href="/">Home</a></li>
								<li><a class="footer__link" href="/apps">Apps</a></li>
								<li><a class="footer__link" href="/blog">Blog</a></li>
								<li><a class="footer__link" href="/contact">Contact</a></li>
								<li><a class="footer__link" href="/privacy">Privacy</a></li>
								<li><a class="footer__link" href="/terms">Terms</a></li>
							</ul>
						</div>

						<!-- Column 3: Our Apps -->
						<div>
							<h3 class="footer__col-title">Our Apps</h3>
							<ul class="space-y-0.5">
								<li><a class="footer__link" href="/apps/bible-tpt">Bible TPT</a></li>
								<li><a class="footer__link" href="/apps/biblia-tla">Biblia TLA</a></li>
								<li><a class="footer__link" href="/apps/cartwise-grocery-shopping-list">CartWise</a></li>
								<li>
									<a class="footer__link" href="/apps/claimly-receipt-tracker">
										Claimly
										<span class="ml-1 inline-flex items-center rounded-full px-1.5 py-0.5 text-[10px] font-bold" style="background: rgba(234,88,12,0.10); color: #ea580c;">Beta</span>
									</a>
								</li>
								<li class="pt-2">
									<a class="footer__link footer__link--accent" href="/apps">
										View All &rarr;
									</a>
								</li>
							</ul>
						</div>

						<!-- Column 4: Connect -->
						<div>
							<h3 class="footer__col-title">Get in Touch</h3>
							<ul class="space-y-1">
								<li>
									<a
