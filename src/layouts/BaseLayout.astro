---
import "@/styles/global.css";

import GooglePlayLogo from "@/assets/gplay-logo.svg";
import ThemeToggle from "@/components/ThemeToggle.tsx";
import { Menu } from "lucide-react";

const {
	title = "FusionCore Apps — Premium Mobile Applications",
	description = "Professional mobile app development studio delivering secure, innovative, and user-friendly applications for Android and iOS platforms. Transform your ideas into powerful digital experiences.",
	ogImage = "/og-default.png",
	canonical,
	noindex = false,
	bodyClass = "",
	showHero = false,
	locale = "en",
	showFooterCta = true,
} = Astro.props;

const year = new Date().getFullYear();
const currentPath = Astro.url.pathname;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;

// Handle ogImage: if it's already a full URL or data URI, use as-is; otherwise make it absolute
const resolvedOgImage =
	ogImage.startsWith("http://") || ogImage.startsWith("https://") || ogImage.startsWith("data:")
		? ogImage
		: new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html class="scroll-smooth" lang={locale}>
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1, viewport-fit=cover" name="viewport" />
		<title>{title}</title>
		<meta content={description} name="description" />
		<meta content={noindex ? "noindex,nofollow" : "index,follow"} name="robots" />
		<link href={canonicalUrl} rel="canonical" />
		<link rel="alternate" hreflang="x-default" href={canonicalUrl} />
		<link rel="alternate" hreflang={locale} href={canonicalUrl} />

		<meta content="website" property="og:type" />
		<meta content={new URL(Astro.url.pathname, Astro.site).href} property="og:url" />
		<meta content={title} property="og:title" />
		<meta content={description} property="og:description" />
		<meta content={resolvedOgImage} property="og:image" />
		<meta content="FusionCore Apps" property="og:site_name" />

		<meta content="summary_large_image" name="twitter:card" />
		<meta content={new URL(Astro.url.pathname, Astro.site).href} name="twitter:url" />
		<meta content={title} name="twitter:title" />
		<meta content={description} name="twitter:description" />
		<meta content={resolvedOgImage} name="twitter:image" />

		<meta content="#2ECFFF" name="theme-color" media="(prefers-color-scheme: light)" />
		<meta content="#0b1c2d" name="theme-color" media="(prefers-color-scheme: dark)" />
		<meta content="light dark" name="color-scheme" />
		<meta content="yes" name="mobile-web-app-capable" />
		<meta content="default" name="apple-mobile-web-app-status-bar-style" />

		<link rel="preload" href="/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin />

		<link href="/favicon.svg" rel="icon" type="image/svg+xml" />
		<link href="/favicon.svg" rel="apple-touch-icon" />

		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Organization",
				"name": "FusionCore Apps",
				"description": "Professional mobile app development studio",
				"url": "https://www.fusioncoreapps.com",
				"logo": "https://www.fusioncoreapps.com/logo.png",
				"foundingDate": "2024",
				"sameAs": ["https://play.google.com/store/apps/developer?id=FusionCore+Apps"]
			}
		</script>

		<script is:inline>
			(function () {
				const stored = localStorage.getItem("theme");
				const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				const isDark = stored === "dark" || (!stored && prefersDark);

				if (isDark) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
		<slot name="head" />

		<!-- Firebase Analytics -->
		{import.meta.env.PUBLIC_FIREBASE_MEASUREMENT_ID && (
			<script type="module" define:vars={{
				apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
				authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
				projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
				storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
				messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
				appId: import.meta.env.PUBLIC_FIREBASE_APP_ID,
				measurementId: import.meta.env.PUBLIC_FIREBASE_MEASUREMENT_ID,
			}}>
				import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.0/firebase-app.js";
				import { getAnalytics } from "https://www.gstatic.com/firebasejs/11.6.0/firebase-analytics.js";
				const app = initializeApp({ apiKey, authDomain, projectId, storageBucket, messagingSenderId, appId, measurementId });
				getAnalytics(app);
			</script>
		)}
	</head><body class:list={[`min-h-screen antialiased`, `${bodyClass}`]}>
		<!-- Skip to content link for accessibility -->
		<a
			class="button button--primary sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50"
			href="#main"
		>
			Skip to main content
		</a>

		<!-- Header -->
		<header
			class="header sticky top-0 z-40 border-b border-gray-200/50 bg-white/80 backdrop-blur-lg dark:border-gray-800/50 dark:bg-gray-950/80"
		>
			<nav
				aria-label="Main navigation"
				class="header__nav mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
				role="navigation"
			>
				<!-- Logo -->
				<a
					class="header__logo hover:text-brand-600 dark:hover:text-brand-400 group flex items-center gap-3 text-xl font-bold text-gray-900 transition-colors dark:text-white"
					href="/"
				>
					<div
						class="flex h-14 w-14 items-center justify-center rounded-lg bg-gradient-to-br transition-all duration-200 group-hover:scale-105"
					>
						<img alt="FusionCore Apps Logo" class="h-12 w-12 object-contain" src="/logo.png" />
					</div>
					<span class="gradient-text">FusionCore Apps</span>
				</a>

				<!-- Desktop Navigation -->
				<ul class="header__nav-links hidden items-center gap-8 md:flex" role="menubar">
					<li role="none">
						<a
							class:list={[`nav-link`, { "nav-link--active": currentPath.startsWith("/apps") }]}
							href="/apps"
							role="menuitem"
						>
							Apps
						</a>
					</li>
					<li role="none">
						<a
							class:list={[`nav-link`, { "nav-link--active": currentPath.startsWith("/blog") }]}
							href="/blog"
							role="menuitem"
						>
							Blog
						</a>
					</li>
					<li role="none">
						<a
							class:list={[`nav-link`, { "nav-link--active": currentPath === "/privacy" }]}
							href="/privacy"
							role="menuitem"
						>
							Privacy
						</a>
					</li>
					<li role="none">
						<a
							class:list={[`nav-link`, { "nav-link--active": currentPath === "/contact" }]}
							href="/contact"
							role="menuitem"
						>
							Contact
						</a>
					</li>
				</ul>

				<!-- Theme Toggle & Mobile Menu -->
				<div class="header__actions flex items-center gap-3">
					<ThemeToggle client:load />

					<!-- Mobile menu button -->
					<button
						aria-label="Open mobile menu"
						class="hover:text-brand-600 dark:hover:text-brand-400 focus:ring-brand-500 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gray-100 text-gray-600 transition-all duration-200 hover:bg-gray-200 focus:ring-2 focus:outline-none md:hidden dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700"
						id="mobile-menu-button"
					>
						<Menu className="h-5 w-5" stroke="currentColor" />
					</button>
				</div>
			</nav>

			<!-- Mobile Navigation Menu -->
			<div
				class="header__mobile-menu hidden border-t border-gray-200 md:hidden dark:border-gray-800"
				id="mobile-menu"
			>
				<nav aria-label="Mobile navigation" class="px-4 py-4 sm:px-6" role="navigation">
					<ul class="space-y-4" role="menubar">
						<li role="none">
							<a
								class:list={[
									`block rounded-xl px-4 py-2 text-gray-900 transition-colors hover:bg-gray-100 dark:text-gray-100 dark:hover:bg-gray-800`,
									{
										"bg-brand-50 dark:bg-brand-900/20 text-brand-600 dark:text-brand-400":
											currentPath.startsWith("/apps"),
									},
								]}
								href="/apps"
								role="menuitem"
							>
								Apps
							</a>
						</li>
						<li role="none">
							<a
								class:list={[
									`block rounded-xl px-4 py-2 text-gray-900 transition-colors hover:bg-gray-100 dark:text-gray-100 dark:hover:bg-gray-800`,
									{
										"bg-brand-50 dark:bg-brand-900/20 text-brand-600 dark:text-brand-400":
											currentPath.startsWith("/blog"),
									},
								]}
								href="/blog"
								role="menuitem"
							>
								Blog
							</a>
						</li>
						<li role="none">
							<a
								class:list={[
									`block rounded-xl px-4 py-2 text-gray-900 transition-colors hover:bg-gray-100 dark:text-gray-100 dark:hover:bg-gray-800`,
									{
										"bg-brand-50 dark:bg-brand-900/20 text-brand-600 dark:text-brand-400":
											currentPath === "/privacy",
									},
								]}
								href="/privacy"
								role="menuitem"
							>
								Privacy
							</a>
						</li>
						<li role="none">
							<a
								class:list={[
									`block rounded-xl px-4 py-2 text-gray-900 transition-colors hover:bg-gray-100 dark:text-gray-100 dark:hover:bg-gray-800`,
									{
										"bg-brand-50 dark:bg-brand-900/20 text-brand-600 dark:text-brand-400":
											currentPath === "/contact",
									},
								]}
								href="/contact"
								role="menuitem"
							>
								Contact
							</a>
						</li>
					</ul>
				</nav>
			</div>
		</header>

		<!-- Main Content -->
		<main class="main flex-1" id="main" role="main">
			{
				showHero && (
					<section class="hero gradient-bg py-24 sm:py-32">
						<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
							<slot name="hero" />
						</div>
					</section>
				)
			}

			<div class:list={{ "py-16 sm:py-24": showHero, "py-8 sm:py-12": !showHero }}>
				<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
					<slot />
				</div>
			</div>
		</main>

		<!-- Footer -->
		<footer class="footer bg-gray-950 text-gray-300" role="contentinfo">
			<!-- CTA Banner -->
			{showFooterCta && <div class="bg-fusion-gradient">
				<div
					class="mx-auto flex max-w-7xl flex-col items-center gap-6 px-4 py-12 text-center sm:px-6 lg:px-8"
				>
					<h2 class="text-2xl font-bold text-white sm:text-3xl">Ready to download?</h2>
					<p class="max-w-xl text-lg text-white/90">
						All our apps are free. Find your perfect app on Google Play.
					</p>
					<a
						class="inline-flex items-center rounded-xl bg-white px-6 py-3 text-sm font-semibold text-gray-900 shadow-lg transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl"
						href="/apps"
					>
						Browse Apps
					</a>
				</div>
			</div>}

			<!-- Main footer columns -->
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="footer__content grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
					<!-- Column 1: Brand -->
					<div class="footer__section">
						<a class="footer__logo mb-4 flex items-center gap-3" href="/">
							<div class="flex h-10 w-10 items-center justify-center rounded-lg">
								<img alt="FusionCore Apps Logo" class="h-8 w-8 object-contain" src="/logo.png" />
							</div>
							<span class="text-lg font-bold text-white">FusionCore Apps</span>
						</a>
						<p class="mb-2 text-sm font-medium text-white">
							Premium mobile apps built with excellence.
						</p>
						<p class="footer__description mb-6 max-w-xs text-sm text-gray-400">
							We create free Android apps that are secure, performant, and delightful to use.
						</p>
						<a
							aria-label="Get it on Google Play"
							class="inline-flex items-center gap-2 rounded-lg border border-gray-700 px-4 py-2 text-sm text-gray-300 transition-colors hover:border-gray-500 hover:text-white"
							href="https://play.google.com/store/apps/developer?id=FusionCore+Apps"
							rel="noopener noreferrer"
							target="_blank"
						>
							<GooglePlayLogo class="h-5 w-5" />
							<span>Google Play</span>
						</a>
					</div>

					<!-- Column 2: Quick Links -->
					<div class="footer__section">
						<h3 class="footer__title mb-4 text-sm font-semibold tracking-wider text-white uppercase">
							Quick Links
						</h3>
						<ul class="footer__links space-y-3">
							<li>
								<a class="text-sm text-gray-400 transition-colors hover:text-white" href="/">Home</a>
							</li>
							<li>
								<a class="text-sm text-gray-400 transition-colors hover:text-white" href="/apps"
									>Apps</a
								>
							</li>
							<li>
								<a class="text-sm text-gray-400 transition-colors hover:text-white" href="/blog"
									>Blog</a
								>
							</li>
							<li>
								<a class="text-sm text-gray-400 transition-colors hover:text-white" href="/contact"
									>Contact</a
								>
							</li>
							<li>
								<a class="text-sm text-gray-400 transition-colors hover:text-white" href="/privacy"
									>Privacy Policy</a
								>
							</li>
							<li>
								<a class="text-sm text-gray-400 transition-colors hover:text-white" href="/terms"
									>Terms of Service</a
								>
							</li>
						</ul>
					</div>

					<!-- Column 3: Our Apps -->
					<div class="footer__section">
						<h3 class="footer__title mb-4 text-sm font-semibold tracking-wider text-white uppercase">
							Our Apps
						</h3>
						<ul class="footer__links space-y-3">
							<li>
								<a
									class="text-sm text-gray-400 transition-colors hover:text-white"
									href="/apps/bible-tpt">Bible TPT</a
								>
							</li>
							<li>
								<a
									class="text-sm text-gray-400 transition-colors hover:text-white"
									href="/apps/biblia-tla">Biblia TLA</a
								>
							</li>
							<li>
								<a
									class="text-sm text-gray-400 transition-colors hover:text-white"
									href="/apps/cartwise-grocery-shopping-list">CartWise</a
								>
							</li>
							<li>
								<a
									class="inline-flex items-center gap-1 text-sm font-medium text-brand-400 transition-colors hover:text-brand-300"
									href="/apps"
								>
									View All Apps &rarr;
								</a>
							</li>
						</ul>
					</div>

					<!-- Column 4: Connect -->
					<div class="footer__section">
						<h3 class="footer__title mb-4 text-sm font-semibold tracking-wider text-white uppercase">
							Connect
						</h3>
						<ul class="footer__links space-y-3">
							<li>
								<a
									class="inline-flex items-center gap-2 text-sm text-gray-400 transition-colors hover:text-white"
									href="https://play.google.com/store/apps/developer?id=FusionCore+Apps"
									rel="noopener noreferrer"
									target="_blank"
								>
									<GooglePlayLogo class="h-4 w-4" />
									<span>Google Play Store</span>
								</a>
							</li>
							<li>
								<a
									class="inline-flex items-center gap-2 text-sm text-gray-400 transition-colors hover:text-white"
									href="mailto:jeanrey.ese@gmail.com"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="h-4 w-4"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<rect width="20" height="16" x="2" y="4" rx="2"></rect>
										<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
									</svg>
									<span>jeanrey.ese@gmail.com</span>
								</a>
							</li>
							<li>
								<a
									class="inline-flex items-center gap-2 text-sm text-gray-400 transition-colors hover:text-white"
									href="https://github.com/Z3r0J"
									rel="noopener noreferrer"
									target="_blank"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="h-4 w-4"
										viewBox="0 0 24 24"
										fill="currentColor"
									>
										<path
											d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
										></path>
									</svg>
									<span>GitHub</span>
								</a>
							</li>
						</ul>
					</div>
				</div>

				<!-- Footer bottom -->
				<div
					class="footer__bottom flex flex-col items-center justify-between gap-4 border-t border-gray-800 py-6 sm:flex-row"
				>
					<p class="text-sm text-gray-500">
						&copy; {year} FusionCore Apps. All rights reserved.
					</p>
					<div class="flex items-center gap-6 text-sm text-gray-500">
						<a class="transition-colors hover:text-gray-300" href="/privacy">Privacy Policy</a>
						<span class="text-gray-700">&middot;</span>
						<a class="transition-colors hover:text-gray-300" href="/terms">Terms of Service</a>
					</div>
					<p class="text-sm text-gray-600">Built with care for Android users</p>
				</div>
			</div>
		</footer>

		<!-- Mobile menu toggle script -->
		<script is:inline>
			function setupMobileMenu() {
				const mobileMenuButton = document.getElementById("mobile-menu-button");
				const mobileMenu = document.getElementById("mobile-menu");

				if (mobileMenuButton && mobileMenu) {
					// Prevent adding multiple listeners if function is called multiple times
					// (e.g. DOMContentLoaded and astro:page-load on initial load)
					if (mobileMenuButton.dataset.hasListener) return;

					mobileMenuButton.addEventListener("click", function () {
						mobileMenu.classList.toggle("hidden");
						const isExpanded = !mobileMenu.classList.contains("hidden");
						mobileMenuButton.setAttribute("aria-expanded", isExpanded.toString());
					});

					mobileMenuButton.dataset.hasListener = "true";
				}
			}

			// Run on initial load
			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", setupMobileMenu);
			} else {
				setupMobileMenu();
			}

			// Support Astro View Transitions (if added in the future)
			document.addEventListener("astro:page-load", setupMobileMenu);
		</script>
	</body>
</html>
