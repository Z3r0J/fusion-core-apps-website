---
import type { CollectionEntry } from "astro:content";
const { app, canonical } = Astro.props as { app: CollectionEntry<"apps">; canonical?: string };

const screenshots =
	app.data.screenshots?.length > 0
		? app.data.screenshots.map((s: string) => new URL(s, Astro.site).href)
		: undefined;

const localeToLanguage: Record<string, string> = { en: "en", es: "es-419", pt: "pt-BR" };
const inLanguage = app.data.locale ? (localeToLanguage[app.data.locale] ?? app.data.locale) : undefined;

const isFree = !app.data.price || ["Free", "Gratis", "Grátis", "0"].includes(app.data.price);
const pageUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;

const structuredData = {
	"@context": "https://schema.org",
	"@type": "MobileApplication",
	"name": app.data.title,
	"operatingSystem": "Android",
	"applicationCategory": app.data.category,
	"description": app.data.description,
	"url": pageUrl,
	"downloadUrl": app.data.playUrl,
	"image": app.data.icon ? new URL(app.data.icon, Astro.site).href : undefined,
	...(app.data.version ? { "softwareVersion": app.data.version } : {}),
	...(screenshots ? { "screenshot": screenshots } : {}),
	...(app.data.lastUpdated ? { "dateModified": app.data.lastUpdated } : {}),
	...(inLanguage ? { "inLanguage": inLanguage } : {}),
	"applicationSubCategory": app.data.category,
	"contentRating": "Everyone",
	"author": {
		"@type": "Organization",
		"name": "FusionCore Apps",
		"url": "https://www.fusioncoreapps.com",
	},
	"offers": {
		"@type": "Offer",
		"price": isFree ? "0" : app.data.price,
		...(isFree ? {} : { "priceCurrency": "USD" }),
		"availability": "https://schema.org/InStock",
	},
	"publisher": { "@type": "Organization", "name": "FusionCore Apps" },
	...(app.data.rating && app.data.ratingCount ? {
		"aggregateRating": {
			"@type": "AggregateRating",
			"ratingValue": app.data.rating,
			"ratingCount": app.data.ratingCount,
			"bestRating": 5,
			"worstRating": 1,
		}
	} : {}),
};
---

<!-- eslint-disable astro/no-set-html-directive -->
<script
	is:inline
	set:html={JSON.stringify(structuredData).replace(/</g, "\\u003c")}
	type="application/ld+json"
></script>
