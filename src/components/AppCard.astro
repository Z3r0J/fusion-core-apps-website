---
import PlaceholderApp from "@/assets/placeholder-app.svg";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { Star } from "lucide-react";

const { app, featured = false } = Astro.props as {
	app: CollectionEntry<"apps">;
	featured?: boolean;
};

const rating = app.data.rating ?? null;
const downloads = app.data.downloads ?? null;
const price = app.data.price || "Free";
const category = app.data.category;
const isBeta = app.data.beta ?? false;
const betaGroupUrl = app.data.betaGroupUrl;

const isTopRated = rating !== null && rating >= 4.5;
const modalId = `download-modal-${app.slug}`;

const fullStars = rating !== null ? Math.floor(rating) : 0;
const hasHalfStar = rating !== null && rating - fullStars >= 0.5;

// Per-category accent stage system
type AccentConfig = { bg: string; glow: string };
const categoryAccents: Record<string, AccentConfig> = {
	"Books & Reference": { bg: "linear-gradient(150deg, #160e30 0%, #2b1660 55%, #160e30 100%)", glow: "rgba(139,92,246,0.60)" },
	"Shopping":          { bg: "linear-gradient(150deg, #1a0c04 0%, #3d1f06 55%, #1a0c04 100%)", glow: "rgba(251,146,60,0.60)" },
	"Productivity":      { bg: "linear-gradient(150deg, #031018 0%, #072436 55%, #031018 100%)", glow: "rgba(46,207,255,0.60)" },
	"Utilities":         { bg: "linear-gradient(150deg, #031018 0%, #072436 55%, #031018 100%)", glow: "rgba(46,207,255,0.60)" },
};
const defaultAccent: AccentConfig = { bg: "linear-gradient(150deg, #0b1c2d 0%, #0e2a42 55%, #0b1c2d 100%)", glow: "rgba(46,207,255,0.45)" };
const accent = categoryAccents[category] ?? defaultAccent;
---

<article
	class:list={["app-store-card group relative transition-transform duration-300 hover:-translate-y-1.5", { "app-store-card--featured": featured }]}
>
	<div class="app-store-card__inner overflow-hidden rounded-[22px] bg-white dark:bg-gray-900">

		<!-- ── Stage: colored accent zone ── -->
		<a
			href={`/apps/${app.slug}`}
			class="app-store-card__stage relative block h-[152px] overflow-hidden select-none"
			style={`background: ${accent.bg};`}
			tabindex="-1"
			aria-hidden="true"
		>
			<!-- Glow blob behind icon -->
			<div
				class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[90px] w-[90px] rounded-full blur-2xl transition-all duration-500 group-hover:h-28 group-hover:w-28"
				style={`background: ${accent.glow};`}
			></div>

			<!-- App Icon — scales on hover -->
			<div class="absolute inset-0 flex items-center justify-center">
				{
					app.data.icon ? (
						<Image
							src={app.data.icon}
							alt={`${app.data.title} icon`}
							width={76}
							height={76}
							loading="lazy"
							class="rounded-[18px] shadow-[0_10px_36px_rgba(0,0,0,0.50)] ring-1 ring-white/15 transition-transform duration-500 group-hover:scale-[1.12]"
						/>
					) : (
						<PlaceholderApp class="h-[76px] w-[76px] rounded-[18px] shadow-[0_10px_36px_rgba(0,0,0,0.50)] ring-1 ring-white/15 transition-transform duration-500 group-hover:scale-[1.12]" />
					)
				}
			</div>

			<!-- Bottom gradient veil -->
			<div
				class="pointer-events-none absolute inset-x-0 bottom-0 h-12"
				style="background: linear-gradient(to top, rgba(0,0,0,0.50) 0%, transparent 100%);"
			></div>

			<!-- Category label — bottom left -->
			<div class="absolute bottom-2.5 left-4">
				<span
					class="text-[10px] font-bold tracking-[0.12em] uppercase"
					style="color: rgba(255,255,255,0.48);"
				>{category}</span>
			</div>

			<!-- Price — top right (frosted pill) -->
			<div class="absolute top-3 right-3">
				<span
					class="inline-flex items-center rounded-full px-2.5 py-1 text-[11px] font-bold"
					style="background: rgba(0,0,0,0.38); color: rgba(255,255,255,0.90); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.12);"
				>{price}</span>
			</div>

			<!-- Status badges — top left -->
			<div class="absolute top-3 left-3 flex items-center gap-1.5">
				{isBeta && (
					<span
						class="inline-flex items-center rounded-full px-2.5 py-1 text-[11px] font-bold"
						style="background: rgba(234,88,12,0.92); color: #fff; backdrop-filter: blur(8px);"
					>Beta</span>
				)}
				{!isBeta && isTopRated && (
					<span
						class="inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-[11px] font-bold"
						style="background: rgba(0,0,0,0.40); color: #fbbf24; backdrop-filter: blur(8px); border: 1px solid rgba(251,191,36,0.22);"
					>★ Top Rated</span>
				)}
				{featured && (
					<span
						class="inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-[11px] font-bold"
						style="background: rgba(46,207,255,0.18); color: #7fe9ff; backdrop-filter: blur(8px); border: 1px solid rgba(46,207,255,0.22);"
					>✦ Featured</span>
				)}
			</div>
		</a>

		<!-- ── Card Body ── -->
		<a
			href={`/apps/${app.slug}`}
			class="block px-5 pt-4 pb-3 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-inset"
		>
			<h3
				class="truncate font-bold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors duration-200"
				style="font-family: var(--font-display); font-size: 15px; letter-spacing: -0.025em;"
			>
				{app.data.title}
			</h3>
			<p class="mt-1 text-sm text-gray-500 dark:text-gray-400 leading-snug line-clamp-2">
				{app.data.tagline}
			</p>

			{rating !== null && (
				<div class="mt-3 flex items-center gap-2.5">
					<div class="flex items-center gap-0.5" aria-label={`Rating ${rating} out of 5`}>
						{
							Array.from({ length: 5 }).map((_, i) => (
								<Star
									className={`h-3 w-3 ${i < fullStars ? "fill-current text-yellow-400" : i === fullStars && hasHalfStar ? "fill-current text-yellow-300" : "text-gray-200 dark:text-gray-700"}`}
									fill="currentColor"
								/>
							))
						}
					</div>
					<span class="text-[11px] font-semibold text-gray-400 dark:text-gray-500">{rating}</span>
					{downloads && <span class="text-[11px] text-gray-400 dark:text-gray-500">&middot; {downloads}</span>}
				</div>
			)}
		</a>

		<!-- ── CTA Footer ── -->
		<div class="px-5 pb-5 pt-2">
			<div class="border-t border-gray-100 dark:border-gray-800 pt-3.5">
				{isBeta ? (
					<a
						href={betaGroupUrl ?? app.data.playUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="app-store-card__btn app-store-card__btn--beta flex w-full items-center justify-center gap-2 rounded-[12px] px-4 py-2.5 text-[13px] font-semibold text-white"
					>
						<svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
						<span>Join Beta — It's Free</span>
					</a>
				) : (
					<button
						type="button"
						data-modal-id={modalId}
						class="download-btn app-store-card__btn app-store-card__btn--play flex w-full items-center justify-center gap-2 rounded-[12px] px-4 py-2.5 text-[13px] font-semibold text-white"
					>
						<svg class="h-3.5 w-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
							<path d="M3 20.5V3.5C3 2.91 3.34 2.39 3.84 2.15L13.69 12L3.84 21.85C3.34 21.6 3 21.09 3 20.5Z" opacity="0.8"/>
							<path d="M16.81 15.12L6.05 21.34L14.54 12.85L16.81 15.12Z" opacity="0.65"/>
							<path d="M20.16 10.81C20.5 11.08 20.75 11.5 20.75 12C20.75 12.5 20.53 12.9 20.18 13.18L17.89 14.5L15.39 12L17.89 9.5L20.16 10.81Z"/>
							<path d="M6.05 2.66L16.81 8.88L14.54 11.15L6.05 2.66Z" opacity="0.65"/>
						</svg>
						<span>Get on Google Play</span>
					</button>
				)}
			</div>
		</div>
	</div>
</article>

<!-- ── Download Modal (unchanged) ── -->
<div
	id={modalId}
	class="download-modal fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm"
	aria-hidden="true"
>
	<div
		class="modal-content relative m-4 max-w-md rounded-2xl bg-white p-6 shadow-2xl dark:bg-gray-800"
		role="dialog"
		aria-modal="true"
		aria-labelledby={`${modalId}-title`}
	>
		<button
			type="button"
			class="close-modal absolute top-4 right-4 text-gray-400 transition-colors hover:text-gray-600 dark:hover:text-gray-200"
			aria-label="Close"
		>
			<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
			</svg>
		</button>

		<div class="mb-6">
			<div class="mb-4 flex items-center gap-3">
				{
					app.data.icon ? (
						<Image
							alt={`${app.data.title} app icon`}
							class="h-12 w-12 rounded-xl"
							height={48}
							loading="lazy"
							src={app.data.icon}
							width={48}
						/>
					) : (
						<PlaceholderApp class="h-12 w-12 rounded-xl" />
					)
				}
				<div>
					<h3 id={`${modalId}-title`} class="text-xl font-bold text-gray-900 dark:text-white">
						{app.data.title}
					</h3>
				</div>
			</div>
			<p class="text-sm text-gray-600 dark:text-gray-400">Choose your platform to download</p>
		</div>

		<div class="space-y-3">
			<a
				href={app.data.playUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="hover:border-brand-500 dark:hover:border-brand-400 flex items-center gap-4 rounded-xl border-2 border-gray-200 bg-white p-4 transition-all hover:shadow-md dark:border-gray-700 dark:bg-gray-900"
			>
				<div class="flex-shrink-0">
					<svg class="h-10 w-10" viewBox="0 0 24 24" fill="none">
						<path d="M3 20.5V3.5C3 2.91 3.34 2.39 3.84 2.15L13.69 12L3.84 21.85C3.34 21.6 3 21.09 3 20.5Z" fill="#00D6FF"></path>
						<path d="M16.81 15.12L6.05 21.34L14.54 12.85L16.81 15.12Z" fill="#FFC107"></path>
						<path d="M20.16 10.81C20.5 11.08 20.75 11.5 20.75 12C20.75 12.5 20.53 12.9 20.18 13.18L17.89 14.5L15.39 12L17.89 9.5L20.16 10.81Z" fill="#FF3E00"></path>
						<path d="M6.05 2.66L16.81 8.88L14.54 11.15L6.05 2.66Z" fill="#00E081"></path>
					</svg>
				</div>
				<div class="flex-1 text-left">
					<div class="text-sm font-semibold text-gray-900 dark:text-white">Google Play</div>
					<div class="text-xs text-gray-500 dark:text-gray-400">Download for Android</div>
				</div>
				<svg class="h-5 w-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6" />
				</svg>
			</a>

			{
				app.data.appStoreUrl && (
					<a
						href={app.data.appStoreUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="hover:border-brand-500 dark:hover:border-brand-400 flex items-center gap-4 rounded-xl border-2 border-gray-200 bg-white p-4 transition-all hover:shadow-md dark:border-gray-700 dark:bg-gray-900"
					>
						<div class="flex-shrink-0">
							<svg class="h-10 w-10" viewBox="0 0 24 24" fill="currentColor">
								<path
									d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.1 22C7.79 22.05 6.8 20.68 5.96 19.47C4.25 17 2.94 12.45 4.7 9.39C5.57 7.87 7.13 6.91 8.82 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"
									class="text-gray-900 dark:text-white"
								/>
							</svg>
						</div>
						<div class="flex-1 text-left">
							<div class="text-sm font-semibold text-gray-900 dark:text-white">App Store</div>
							<div class="text-xs text-gray-500 dark:text-gray-400">Download for iOS</div>
						</div>
						<svg class="h-5 w-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6" />
						</svg>
					</a>
				)
			}
		</div>
	</div>
</div>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		document.querySelectorAll(".download-btn").forEach((btn) => {
			btn.addEventListener("click", (e) => {
				e.preventDefault();
				e.stopPropagation();
				const modalId = (e.currentTarget as HTMLElement).dataset.modalId;
				const modal = document.getElementById(modalId as string);
				if (modal) {
					modal.classList.remove("hidden");
					modal.classList.add("flex");
					modal.setAttribute("aria-hidden", "false");
					document.body.style.overflow = "hidden";
				}
			});
		});

		const closeModal = (modal: HTMLElement) => {
			modal.classList.add("hidden");
			modal.classList.remove("flex");
			modal.setAttribute("aria-hidden", "true");
			document.body.style.overflow = "";
		};

		document.querySelectorAll(".close-modal").forEach((btn) => {
			btn.addEventListener("click", (e) => {
				const modal = (e.target as HTMLElement).closest(".download-modal");
				if (modal) closeModal(modal as HTMLElement);
			});
		});

		document.querySelectorAll(".download-modal").forEach((modal) => {
			modal.addEventListener("click", (e) => {
				if (e.target === modal) closeModal(modal as HTMLElement);
			});
		});

		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape") {
				document.querySelectorAll(".download-modal").forEach((modal) => {
					if (!modal.classList.contains("hidden")) closeModal(modal as HTMLElement);
				});
			}
		});
	});
</script>
