<script>
  function setupFaq() {
    const btns = document.querySelectorAll<HTMLButtonElement>("[data-faq-btn]");
    btns.forEach((btn) => {
      // Remove old listener by cloning
      const fresh = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(fresh, btn);
      fresh.addEventListener("click", () => {
        const item = fresh.closest(".faq-item");
        if (!item) return;
        const isOpen = item.classList.contains("faq-item--open");
        // Close all
        document.querySelectorAll(".faq-item").forEach((el) => {
          el.classList.remove("faq-item--open");
          el.querySelector("[data-faq-btn]")?.setAttribute("aria-expanded", "false");
        });
        // Open clicked if it was closed
        if (!isOpen) {
          item.classList.add("faq-item--open");
          fresh.setAttribute("aria-expanded", "true");
        }
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupFaq);
  } else {
    setupFaq();
  }
  document.addEventListener("astro:page-load", setupFaq);
</script>
