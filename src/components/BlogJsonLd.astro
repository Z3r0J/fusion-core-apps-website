---
import type { CollectionEntry } from "astro:content";

const { post, url } = Astro.props as { post: CollectionEntry<"blog">; url: string };

const siteUrl = Astro.site?.href.replace(/\/$/, "") ?? "https://www.fusioncoreapps.com";

const structuredData = {
	"@context": "https://schema.org",
	"@type": "Article",
	"headline": post.data.title,
	"description": post.data.description,
	"datePublished": post.data.publishedAt.toISOString(),
	"dateModified": (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": url,
	},
	"image": post.data.image
		? new URL(post.data.image, Astro.site).href
		: `${siteUrl}/og-default.png`,
	"author": {
		"@type": "Organization",
		"name": "FusionCore Apps",
		"url": "https://www.fusioncoreapps.com",
	},
	"publisher": {
		"@type": "Organization",
		"name": "FusionCore Apps",
		"logo": {
			"@type": "ImageObject",
			"url": "https://www.fusioncoreapps.com/logo.png",
			"width": 528,
			"height": 551,
		},
	},
	"url": url,
};

const faqData = post.data.faq?.length
	? {
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": post.data.faq.map((item) => ({
				"@type": "Question",
				"name": item.question,
				"acceptedAnswer": {
					"@type": "Answer",
					"text": item.answer,
				},
			})),
		}
	: null;
---

<!-- eslint-disable astro/no-set-html-directive -->
<script
	is:inline
	set:html={JSON.stringify(structuredData).replace(/</g, "\\u003c")}
	type="application/ld+json"
></script>
{
	faqData && (
		<script
			is:inline
			set:html={JSON.stringify(faqData).replace(/</g, "\\u003c")}
			type="application/ld+json"
		/>
	)
}
