                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </span>
              <span set:html={inlineMd(item)} />
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Competitor card -->
    <div class="rounded-[18px] p-7 border border-gray-200/90 dark:border-white/7 bg-white dark:bg-white/3">
      <div class="flex items-center gap-3.5 mb-5 pb-4 border-b border-gray-200/80 dark:border-white/7">
        <div class="w-12 h-12 rounded-[12px] overflow-hidden flex-shrink-0 flex items-center justify-center text-3xl shadow-md" style="background:#e8f4fd;">
          {competitorIcon ? (
            <img
              src={competitorIcon}
              alt={`${competitorName} icon`}
              width="48" height="48"
              class="w-full h-full object-cover rounded-[12px]"
              onerror={`this.style.display='none';this.parentNode.innerHTML='${competitorIconEmoji}';`}
            />
          ) : (
            competitorIconEmoji
          )}
