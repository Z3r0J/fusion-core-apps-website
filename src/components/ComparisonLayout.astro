      {t("cartwiseCompare.cta.headline").replace("{{competitor}}", competitorName)}
    </h2>
    <p class="text-white/55 text-base mb-8 leading-relaxed">
      {t("cartwiseCompare.cta.subline")}
    </p>

    <a
      href={PLAY_URL}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 px-7 py-4 rounded-[14px] text-base font-bold text-gray-950 mb-6 transition-transform hover:-translate-y-0.5"
      style="background: var(--color-accent-500);"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 20.5V3.5C3 2.91 3.34 2.39 3.84 2.15L13.69 12L3.84 21.85C3.34 21.6 3 21.09 3 20.5Z" fill="currentColor" opacity="0.9"/>
        <path d="M16.81 15.12L6.05 21.34L14.54 12.85L16.81 15.12Z" fill="currentColor" opacity="0.7"/>
        <path d="M20.16 10.81C20.5 11.08 20.75 11.5 20.75 12C20.75 12.5 20.53 12.9 20.18 13.18L17.89 14.5L15.39 12L17.89 9.5L20.16 10.81Z" fill="currentColor"/>
        <path d="M6.05 2.66L16.81 8.88L14.54 11.15L6.05 2.66Z" fill="currentColor" opacity="0.7"/>
      </svg>
      {t("cartwiseCompare.cta.ctaButton")}
