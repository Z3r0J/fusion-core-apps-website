        <div class="min-w-0">
          <div class="text-xl font-black font-display tracking-tight text-gray-900 dark:text-gray-100">{competitorName}</div>
          <div class="text-xs text-gray-500 dark:text-white/40 mt-0.5">Shopping List · iOS + Android · Free</div>
        </div>
        {competitorRating !== undefined && (
          <div class="ml-auto flex-shrink-0 inline-flex items-center gap-2 px-3 py-1.5 rounded-[10px] text-xs font-semibold border"
            style="background:#f8fafc;border-color:#e2e8f0;color:#64748b;">
            <span style="color:#94a3b8;">{starRow(competitorRating)}</span>
            <span style="color:#64748b;">{competitorRating}</span>
          </div>
        )}
      </div>

      <div class="mb-4">
        <div class="text-[11px] font-bold tracking-[0.1em] uppercase text-emerald-600 dark:text-emerald-400 mb-3">
          {t("cartwiseCompare.procon.goodLabel")}
        </div>
        <ul class="space-y-2.5">
          {competitorGood.map((item) => (
            <li class="flex items-start gap-2.5 text-sm leading-snug text-gray-600 dark:text-white/70">
              <span class="flex-shrink-0 mt-0.5 w-[18px] h-[18px] rounded-full flex items-center justify-center border"
                style="background:rgba(5,150,105,0.1);border-color:rgba(5,150,105,0.25);">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span set:html={inlineMd(item)} />
            </li>
          ))}
        </ul>
      </div>

      <div>
        <div class="text-[11px] font-bold tracking-[0.1em] uppercase text-gray-400 dark:text-white/30 mb-3">
          {t("cartwiseCompare.procon.badLabel")}
        </div>
        <ul class="space-y-2.5">
          {competitorBad.map((item) => (
            <li class="flex items-start gap-2.5 text-sm leading-snug text-gray-600 dark:text-white/70">
              <span class="flex-shrink-0 mt-0.5 w-[18px] h-[18px] rounded-full flex items-center justify-center border"
                style="background:rgba(148,163,184,0.1);border-color:rgba(148,163,184,0.2);">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </span>
              <span set:html={inlineMd(item)} />
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- 6. Feature matrix -->
  <section>
    <div class="inline-flex items-center gap-2 mb-4">
            <span class="text-[12px] font-medium text-gray-500 dark:text-gray-400">
        {t("cartwiseCompare.featureTable.eyebrow")}
      </span>
    </div>
    <p class="text-sm text-gray-500 dark:text-white/40 mb-6 leading-relaxed">
      {t("cartwiseCompare.featureTable.subhead")}
    </p>

    <div class="overflow-x-auto rounded-2xl border border-gray-200/90 dark:border-white/7">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr>
            <th class="text-left px-[18px] py-3.5 text-sm font-bold font-display text-gray-500 dark:text-white/40 border-b border-gray-200/90 dark:border-white/7" style="width:45%;">
              {t("cartwiseCompare.featureTable.colFeature")}
            </th>
            <th class="text-center px-[18px] py-3.5 text-sm font-bold font-display text-white border-t-2 border-brand-400 rounded-tl-xl" style="background: var(--color-tech-blue);width:27.5%;">
              <div>CartWise</div>
              <div class="mt-1 inline-flex items-center gap-1 text-[10px] font-bold tracking-wider text-brand-400 bg-brand-400/12 border border-brand-400/22 rounded-full px-2 py-0.5">
                {t("cartwiseCompare.featureTable.winnerBadge")}
              </div>
            </th>
            <th class="text-center px-[18px] py-3.5 text-sm font-bold font-display text-gray-600 dark:text-white/60 bg-gray-50 dark:bg-white/3 border border-gray-200/90 dark:border-white/7 border-l-0 rounded-tr-xl" style="width:27.5%;border-bottom:none;">
              {competitorName}
            </th>
          </tr>
        </thead>
        <tbody>
          {featureRows.map((row, i) => {
            const cwType = cellType(row.cartwise);
            const compType = cellType(row.competitor);
            const isLast = i === featureRows.length - 1;
            return (
              <tr class="hover:bg-brand-400/[0.015] dark:hover:bg-brand-400/[0.025] transition-colors">
                <td class={`px-[18px] py-3 font-medium text-gray-600 dark:text-white/72 border-b border-gray-200/60 dark:border-white/5 ${isLast ? "border-b-0" : ""}`}>
                  {row.feature}
                </td>
                <td class={`px-[18px] py-3 text-center bg-brand-400/4 dark:bg-brand-400/6 border-l-2 border-r-2 border-brand-400/12 border-b border-gray-200/60 dark:border-white/5 ${isLast ? "border-b-0" : ""}`}>
                  {cwType === "yes" && (
                    <span class="inline-flex items-center justify-center gap-1 text-[13px] font-semibold text-brand-700 dark:text-brand-400" set:html={`${ICON_SVG_CHECK} Yes`} />
                  )}
                  {cwType === "no" && (
                    <span class="inline-flex items-center justify-center gap-1 text-[13px] font-medium text-gray-400 dark:text-white/25" set:html={`${ICON_SVG_X} No`} />
                  )}
                  {cwType === "partial" && (
                    <span class="inline-flex items-center justify-center gap-1 text-xs font-semibold text-gray-500 dark:text-white/50 bg-gray-500/8 dark:bg-white/5 rounded-md px-2 py-0.5">{row.cartwise}</span>
                  )}
                </td>
                <td class={`px-[18px] py-3 text-center border-b border-gray-200/60 dark:border-white/5 ${isLast ? "border-b-0" : ""}`}>
                  {compType === "yes" && (
                    <span class="inline-flex items-center justify-center gap-1 text-[13px] font-semibold text-brand-700 dark:text-brand-400" set:html={`${ICON_SVG_CHECK} Yes`} />
                  )}
                  {compType === "no" && (
                    <span class="inline-flex items-center justify-center gap-1 text-[13px] font-medium text-gray-400 dark:text-white/25" set:html={`${ICON_SVG_X} No`} />
                  )}
                  {compType === "partial" && (
                    <span class="inline-flex items-center justify-center gap-1 text-xs font-semibold text-gray-500 dark:text-white/50 bg-gray-500/8 dark:bg-white/5 rounded-md px-2 py-0.5">{row.competitor}</span>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-400 dark:text-white/30 mt-3 leading-relaxed">
      {t("cartwiseCompare.featureTable.footnote")}
    </p>
  </section>

  <!-- 7. Mid winner callout -->
  <section>
    <div class="relative overflow-hidden rounded-[20px] p-9 lg:p-10 cta-panel">
      <div class="relative z-[1]">
        <div class="inline-flex items-center gap-1.5 text-[11px] font-bold tracking-[0.12em] uppercase text-brand-400 mb-3">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          {t("cartwiseCompare.winnerCallout.label")}
        </div>
        <p class="text-white/65 text-sm leading-[1.65]" style="max-width:540px;">
          {midVerdict}
        </p>
      </div>
    </div>
  </section>

  <!-- 8. Prose body (slot) -->
  <section>
    <div class="prose prose-gray dark:prose-invert max-w-none">
      <slot />
    </div>
  </section>

  <!-- 9. Final verdict -->
  {finalVerdict.length > 0 && (
    <section>
      <div class="relative overflow-hidden rounded-[20px] p-9 border border-brand-400/20 bg-brand-50 dark:bg-white/[0.03]">
        <div class="space-y-4">
          {finalVerdict.map((p) => (
            <p class="text-gray-700 dark:text-white/70 leading-[1.75] text-[15px]">{p}</p>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 10. Mid CTA band -->
  <section>
    <div class="relative overflow-hidden rounded-[20px] p-8 lg:p-9 cta-panel">
      <div class="relative z-[1] flex flex-wrap items-center justify-between gap-6">
        <div>
          <h3 class="subsection-title text-white mb-1">
            {t("cartwiseCompare.ctaMid.headline")}
          </h3>
          <p class="text-white/60 text-sm">{t("cartwiseCompare.ctaMid.subline")}</p>
        </div>
        <a
          href={PLAY_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-[14px] text-[15px] font-bold text-gray-950 flex-shrink-0 transition-transform hover:-translate-y-0.5"
          style="background: var(--color-accent-500);"
        >
          {t("cartwiseCompare.ctaMid.button")}
        </a>
      </div>
    </div>
  </section>

  <!-- 11. Related cards -->
  {relatedItems.length > 0 && (
    <section>
      <div class="inline-flex items-center gap-2 mb-2">
                <span class="text-[12px] font-medium text-gray-500 dark:text-gray-400">
          {t("cartwiseCompare.related.label")}
        </span>
      </div>
      <h2 class="subsection-title mb-6">
        {t("cartwiseCompare.related.heading")}
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {relatedItems.map((item) => {
          const href = locale === "en"
            ? `/compare-apps/cartwise-vs-${item.slug}`
            : `/${locale}/compare-apps/cartwise-vs-${item.slug}`;
          return (
            <a
              href={href}
              class="block rounded-[14px] p-5 bg-white dark:bg-white/3 border border-gray-200/90 dark:border-white/7 no-underline transition-all hover:-translate-y-0.5 hover:border-gray-300 dark:hover:border-white/15 hover:shadow-md"
            >
              <div class="text-[10px] font-bold tracking-[0.1em] uppercase text-brand-700 dark:text-brand-400 mb-1.5">
                {t("cartwiseCompare.related.cardTag")}
              </div>
              <div class="font-display font-bold text-[15px] text-gray-900 dark:text-gray-50 leading-snug mb-1">
                CartWise vs {item.competitorName}
              </div>
              <div class="text-xs text-gray-400 dark:text-white/35">
                CartWise vs {item.competitorName}
              </div>
            </a>
          );
        })}

        <!-- See all card -->
        <a
          href={compareHref}
          class="block rounded-[14px] p-5 bg-white dark:bg-white/3 border border-dashed border-gray-300 dark:border-white/12 no-underline transition-all hover:-translate-y-0.5 hover:border-brand-400/30"
        >
          <div class="text-[10px] font-bold tracking-[0.1em] uppercase text-gray-400 dark:text-white/35 mb-1.5">
            {t("cartwiseCompare.related.seeAllLabel")}
          </div>
          <div class="font-display font-bold text-[15px] text-gray-900 dark:text-gray-50 leading-snug mb-1">
            {t("cartwiseCompare.related.seeAllTitle")}
          </div>
          <div class="text-xs text-gray-400 dark:text-white/35">
            {t("cartwiseCompare.related.seeAllSub")}
          </div>
        </a>
      </div>
    </section>
  )}
</div>

<!-- ══════════════════════════════════════════════════════ -->
<!-- 12. FINAL CTA BAND                                    -->
<!-- ══════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden cta-band">
  <div class="relative z-[1] mx-auto px-6 py-16 lg:py-20 text-center" style="max-width:640px;">
    <div class="inline-flex items-center gap-2 mb-4">
      <span class="text-[12px] font-medium text-white/55">
