---
import type { CollectionEntry } from "astro:content";

const { post } = Astro.props as { post: CollectionEntry<"blog"> };

const formattedDate = post.data.publishedAt.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
---

<article class="card card--elevated group transition-all duration-300 hover:scale-105">
	<a class="block" href={`/blog/${post.slug}`}>
		<!-- Cover Image or Gradient Placeholder -->
		<div class="relative h-48 w-full overflow-hidden rounded-t-2xl">
			{
				post.data.image ? (
					<img
						alt={post.data.title}
						class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-110"
						loading="lazy"
						src={post.data.image}
					/>
				) : (
					<div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-[#2ECFFF] to-[#FF8A2A] opacity-80">
						<svg
							class="h-12 w-12 text-white/60"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
							/>
						</svg>
					</div>
				)
			}
			{
				post.data.featured && (
					<span class="absolute top-3 right-3 rounded-full bg-accent-500 px-2.5 py-1 text-xs font-semibold text-white shadow-md">
						Featured
					</span>
				)
			}
		</div>

		<!-- Content -->
		<div class="p-6">
			<!-- Tags -->
			{
				post.data.tags.length > 0 && (
					<div class="mb-3 flex flex-wrap gap-2">
						{post.data.tags.slice(0, 3).map((tag) => (
							<span class="inline-flex items-center rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-medium text-brand-700 dark:bg-brand-900/30 dark:text-brand-400">
								{tag}
							</span>
						))}
					</div>
				)
			}

			<!-- Title -->
			<h3
				class="group-hover:text-brand-600 dark:group-hover:text-brand-400 mb-2 text-lg font-bold text-gray-900 transition-colors duration-200 dark:text-white"
			>
				{post.data.title}
			</h3>

			<!-- Description -->
			<p class="line-clamp-3 mb-4 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
				{post.data.description}
			</p>

			<!-- Meta -->
			<div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
				<div class="flex items-center gap-2">
					<span>{post.data.author}</span>
					<span aria-hidden="true">&middot;</span>
					<time datetime={post.data.publishedAt.toISOString()}>{formattedDate}</time>
				</div>
			</div>

			<!-- Read more -->
			<div class="mt-4">
				<span
					class="text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 text-sm font-medium transition-colors"
				>
					Read more &rarr;
				</span>
			</div>
		</div>
	</a>
</article>
