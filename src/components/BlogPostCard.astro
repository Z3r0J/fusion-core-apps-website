---
import type { CollectionEntry } from "astro:content";

interface Props {
	post: CollectionEntry<"blog">;
	featured?: boolean;
	index?: number;
	href?: string;
}

const { post, featured = false, index = 0, href: hrefProp } = Astro.props;
const postSlug = post.slug.replace(/^(en|es|pt)\//, "");
const postLocale = post.slug.match(/^(es|pt)\//)?.[1];
const href = hrefProp ?? (postLocale ? `/${postLocale}/blog/${postSlug}` : `/blog/${postSlug}`);

const formattedDate = post.data.publishedAt.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

const delay = `${index * 75}ms`;
---

{
	featured ? (
		<article class="blog-card blog-card--featured" style={`animation-delay:${delay}`}>
			<a class="contents" href={href}>
				{/* ── Image side ── */}
				<div class="blog-card__image" style="min-height:260px;">
					{post.data.image ? (
						<img alt={post.data.title} loading="eager" src={post.data.image} />
					) : (
						<div class="blog-card__image-placeholder">
							<svg
								aria-hidden="true"
								fill="none"
								height="88"
								stroke="#2ECFFF"
								stroke-width="1"
								viewBox="0 0 24 24"
								width="88"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
								/>
							</svg>
						</div>
					)}
				</div>

				{/* ── Content side ── */}
				<div class="blog-card__body justify-center py-10 px-8 md:px-10">
					<div class="mb-5 flex flex-wrap items-center gap-2">
						<span class="blog-featured-badge">Featured</span>
						{post.data.tags.slice(0, 2).map((tag) => (
							<span class="blog-tag">{tag}</span>
						))}
					</div>

					<h2 class="blog-card__title blog-card__title--lg mb-4">{post.data.title}</h2>

					<p class="blog-card__excerpt mb-6 text-[15px]" style="-webkit-line-clamp:4">
						{post.data.description}
					</p>

					<div class="blog-card__meta mb-7">
						<span class="author font-semibold" style="color:inherit">{post.data.author}</span>
						<span class="sep" aria-hidden="true">·</span>
						<time datetime={post.data.publishedAt.toISOString()}>{formattedDate}</time>
					</div>

					<span class="blog-card__cta">
						Read article
						<svg aria-hidden="true" fill="none" height="14" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" width="14">
							<path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</span>
				</div>
			</a>
		</article>
	) : (
		<article class="blog-card flex flex-col" style={`animation-delay:${delay}`}>
			<a class="flex flex-col flex-1" href={href}>
				{/* ── Image stage ── */}
				<div class="blog-card__image" style="height:188px;flex-shrink:0;">
					{post.data.image ? (
						<img alt={post.data.title} loading="lazy" src={post.data.image} />
					) : (
						<div class="blog-card__image-placeholder">
							<svg
								aria-hidden="true"
								fill="none"
								height="56"
								stroke="#2ECFFF"
								stroke-width="1"
								viewBox="0 0 24 24"
								width="56"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
								/>
							</svg>
						</div>
					)}
					{post.data.featured && (
						<span class="blog-featured-badge absolute top-3 right-3">Featured</span>
					)}
				</div>

				{/* ── Card body ── */}
				<div class="blog-card__body flex-1">
					{post.data.tags.length > 0 && (
						<div class="mb-3 flex flex-wrap gap-1.5">
							{post.data.tags.slice(0, 3).map((tag) => (
								<span class="blog-tag">{tag}</span>
							))}
						</div>
					)}

					<h3
						class="blog-card__title mb-2"
						style="font-size:clamp(1rem, 2.2vw, 1.15rem);"
					>
						{post.data.title}
					</h3>

					<p class="blog-card__excerpt mb-5 flex-1">{post.data.description}</p>

					<div class="blog-card__meta mb-4">
						<span>{post.data.author}</span>
						<span class="sep" aria-hidden="true">·</span>
						<time datetime={post.data.publishedAt.toISOString()}>{formattedDate}</time>
					</div>

					<span class="blog-card__cta">
						Read more
						<svg aria-hidden="true" fill="none" height="13" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" width="13">
							<path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</span>
				</div>
			</a>
		</article>
	)
}
