# Admin API Key
# Generate a secure random key for production
# Example: openssl rand -hex 32
API_KEY=your-secret-api-key-here

# Public URL (used by Astro)
PUBLIC_SITE_URL=https://fusioncoreapps.com

# Resend API Key for contact form emails
# Sign up at https://resend.com and get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Contact form recipient email
CONTACT_EMAIL_TO=your-email@example.com

# Admin panel PIN (4-6 digits recommended)
ADMIN_PIN=1234

# Firebase Analytics — get these from your Firebase console (Project Settings > General > Your apps)
# These are PUBLIC values (safe to expose in client JS per Firebase docs)
PUBLIC_FIREBASE_API_KEY=your-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
PUBLIC_FIREBASE_APP_ID=your-app-id
PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
