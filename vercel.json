{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "redirects": [
    {
      "source": "/blog/claimly-ya-disponible-google-play",
      "destination": "/es/blog/claimly-ya-disponible-google-play",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "from"
        }
      ],
      "destination": "/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "utm_source"
        }
      ],
      "destination": "/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "utm_medium"
        }
      ],
      "destination": "/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "utm_campaign"
        }
      ],
      "destination": "/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "utm_term"
        }
      ],
      "destination": "/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "utm_content"
        }
      ],
      "destination": "/:path*",
      "permanent": false
    }
  ]
}
